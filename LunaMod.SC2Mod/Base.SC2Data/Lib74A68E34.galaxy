//--------------------------------------------------------------------------------------------------
bool lib74A68E34_gt_AbathurPrestigeSymbioteCreate_Func (bool testConds, bool runActions) {
    // Automatic Variable Declarations
    // Actions
    if (!runActions) {
        return true;
    }

    UnitBehaviorAdd(EventUnit(), "CarapaceDamageResponse", EventUnit(), 1);
    UnitAbilityAdd(EventUnit(), "SymbioteCarapacePrestige");
    if ((UnitFilterMatch(EventUnit(), UnitGetOwner(EventUnit()), UnitFilter((1 << c_targetFilterAir), 0, 0, 0)) == true)) {
        UnitCreate(1, "AbathurSymbioteLeviathan", c_unitCreateIgnoreBirth, UnitGetOwner(UnitBehaviorEffectUnit(EventUnit(), EventUnitBehavior(), c_effectUnitCaster, 0)), UnitGetPosition(EventUnit()), UnitGetFacing(EventUnit()));
        if ((UnitFilterMatch(EventUnit(), UnitGetOwner(EventUnit()), UnitFilter(0, 0, (1 << c_targetFilterMassive), 0)) == true)) {
            UnitSetHeight(UnitLastCreated(), 6.0, 0.0);
        }
        else {
            UnitSetHeight(UnitLastCreated(), 7.0, 0.0);
        }
    }
    else {
        UnitCreate(1, "AbathurSymbioteBrutalisk", c_unitCreateIgnoreBirth, UnitGetOwner(UnitBehaviorEffectUnit(EventUnit(), EventUnitBehavior(), c_effectUnitCaster, 0)), UnitGetPosition(EventUnit()), UnitGetFacing(EventUnit()));
        UnitBehaviorAdd(UnitLastCreated(), "AllUnitBehaviorController", UnitLastCreated(), 1);
        if ((UnitFilterMatch(EventUnit(), UnitGetOwner(EventUnit()), UnitFilter(0, 0, (1 << c_targetFilterMassive), 0)) == true)) {
            UnitSetHeight(UnitLastCreated(), 3.0, 0.0);
        }
        else {
            UnitSetHeight(UnitLastCreated(), 4.0, 0.0);
        }
    }
    UnitCreateEffectUnit(EventUnit(), "SymbioteFollowCP", UnitLastCreated());
    UnitCreateEffectUnit(EventUnit(), "SymbioteCreateSet", UnitLastCreated());
    return true;
}

