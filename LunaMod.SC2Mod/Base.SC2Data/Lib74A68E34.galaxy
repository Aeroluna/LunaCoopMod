// Custom Script
//--------------------------------------------------------------------------------------------------
// Custom Script: ApplyVoicePack
//--------------------------------------------------------------------------------------------------
void voicepack_apply(string reward_id, int player)
{
    int i;
    int count;
    string tmp;
    count = CatalogFieldValueCount(c_gameCatalogReward, reward_id, "ReplacementArray", c_playerAny);
    for (i = 0; i < count; i += 1) {
        tmp = "ReplacementArray[" + IntToString(i) + "]";
        CatalogLinkReplace(
            player,
            c_gameCatalogSound,
            CatalogFieldValueGet(c_gameCatalogReward, reward_id, tmp + ".From", c_playerAny),
            CatalogFieldValueGet(c_gameCatalogReward, reward_id, tmp + ".To", c_playerAny)
        );
    }
}

void lib74A68E34_InitCustomScript () {
}

// Functions
bool lib74A68E34_gf_TransportHasHeroic (unit lp_transport) {
    // Automatic Variable Declarations
    unitgroup auto91D6D4B5_g;
    int auto91D6D4B5_u;
    unit auto91D6D4B5_var;

    // Implementation
    auto91D6D4B5_g = UnitCargoGroup(lp_transport);
    auto91D6D4B5_u = UnitGroupCount(auto91D6D4B5_g, c_unitCountAll);
    for (;; auto91D6D4B5_u -= 1) {
        auto91D6D4B5_var = UnitGroupUnitFromEnd(auto91D6D4B5_g, auto91D6D4B5_u);
        if (auto91D6D4B5_var == null) { break; }
        if ((UnitTypeTestAttribute(UnitGetType(auto91D6D4B5_var), c_unitAttributeHeroic) == true)) {
            return true;
        }

    }
    return false;
}

void lib74A68E34_gf_ZagaraRoachCorpserMasteryHealth (int lp_player) {
    // Variable Declarations
    fixed lv_upgradeCount;
    fixed lv_healthStarting;
    fixed lv_healthPerPoint;
    fixed lv_healthNew;
    fixed lv_damageStarting;
    fixed lv_damagePerPoint;
    fixed lv_damageNew;

    // Automatic Variable Declarations
    // Variable Initialization
    lv_healthStarting = 145.0;
    lv_healthPerPoint = 29.0;
    lv_healthNew = 145.0;
    lv_damageStarting = 16.0;
    lv_damagePerPoint = 0.32;

    // Implementation
    lv_upgradeCount = TechTreeUpgradeCount(lp_player, "MasteryZagaraRoachDropDamageAndHealth", c_techCountCompleteOnly);
    if ((lv_upgradeCount == 0.0)) {
        return ;
    }

    lv_healthNew = (lv_healthStarting+(lv_upgradeCount*lv_healthPerPoint/10));
    CatalogFieldValueSet(c_gameCatalogUnit, "RoachCorpser", "LifeMax", lp_player, IntToString(FixedToInt(lv_healthNew)));
    CatalogFieldValueSet(c_gameCatalogUnit, "RoachCorpser", "LifeStart", lp_player, IntToString(FixedToInt(lv_healthNew)));
    CatalogFieldValueSet(c_gameCatalogUnit, "RoachCorpserBurrowed", "LifeMax", lp_player, IntToString(FixedToInt(lv_healthNew)));
    CatalogFieldValueSet(c_gameCatalogUnit, "RoachCorpserBurrowed", "LifeStart", lp_player, IntToString(FixedToInt(lv_healthNew)));
}

void lib74A68E34_gf_KaraxExtraUnitVitalMastery (int lp_player) {
    // Variable Declarations
    int lv_upgradeCount;

    // Automatic Variable Declarations
    // Variable Initialization

    // Implementation
    lv_upgradeCount = TechTreeUpgradeCount(lp_player, "MasteryKaraxUnitVital", c_techCountCompleteOnly);
    libCOMI_gf_CM_MasteryKaraxUnitVitalIncrease("StalkerPurifier", lp_player, lv_upgradeCount);
    libCOMI_gf_CM_MasteryKaraxUnitVitalIncrease("Disruptor", lp_player, lv_upgradeCount);
}

