bool lib74A68E34_gt_ZagaraSwarmLocusRoachScale_Func (bool testConds, bool runActions) {
    // Variable Declarations
    fixed lv_scaleModifier;
    fixed lv_upgradeCount;
    fixed lv_newScale;

    // Automatic Variable Declarations
    // Variable Initialization
    lv_scaleModifier = 0.02;

    // Conditions
    if (testConds) {
        if (!((UnitGetType(EventUnit()) == "RoachCorpser"))) {
            return false;
        }
    }

    // Actions
    if (!runActions) {
        return true;
    }

    lv_upgradeCount = TechTreeUpgradeCount(UnitGetOwner(EventUnit()), "MasteryZagaraRoachDropDamageAndHealth", c_techCountCompleteOnly);
    lv_newScale = (1+(lv_upgradeCount*lv_scaleModifier));
    TextExpressionSetToken("Param/Expression/lib_74A68E34_E2739024", "A", FixedToText(lv_newScale, c_fixedPrecisionAny));
    ActorSendAsText(libNtve_gf_MainActorofUnit(EventUnit()), TextExpressionAssemble("Param/Expression/lib_74A68E34_E2739024"));
    return true;
}

