        auto0F391FFB_var = UnitGroupUnitFromEnd(auto0F391FFB_g, auto0F391FFB_u);
        if (auto0F391FFB_var == null) { break; }
        if (((UnitGetType(auto0F391FFB_var) != "SwarmLocus") && (UnitHasBehavior2(auto0F391FFB_var, "makeCreep4x4") == true))) {
            UnitGroupAdd(lv_nearbyCreepTumors, auto0F391FFB_var);
