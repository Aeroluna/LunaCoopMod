// Trigger: RaynorStimpackAutocast
//--------------------------------------------------------------------------------------------------
bool lib74A68E34_gt_RaynorStimpackAutocast_Func (bool testConds, bool runActions) {
    // Automatic Variable Declarations
    // Conditions
    if (testConds) {
        if (!(((UnitAbilityExists(EventUnitCreatedUnit(), "Stimpack") == true) || (UnitAbilityExists(EventUnitCreatedUnit(), "StimpackMarauder") == true)))) {
            return false;
        }

        if (!((libCOOC_gf_ActiveCommanderForPlayer(UnitGetOwner(EventUnitCreatedUnit())) == "TerranRaynor"))) {
            return false;
        }
    }

    // Actions
    if (!runActions) {
        return true;
    }

    UnitIssueOrder(EventUnitCreatedUnit(), OrderSetAutoCast(AbilityCommand("Stimpack", 0), true), c_orderQueueAddToFront);
    UnitIssueOrder(EventUnitCreatedUnit(), OrderSetAutoCast(AbilityCommand("StimpackMarauder", 0), true), c_orderQueueAddToFront);
    return true;
}

