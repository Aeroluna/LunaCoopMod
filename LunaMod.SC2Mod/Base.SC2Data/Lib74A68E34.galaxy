// Trigger: GeneralNydusUnloadHero
//--------------------------------------------------------------------------------------------------
bool lib74A68E34_gt_GeneralNydusUnloadHero_Func (bool testConds, bool runActions) {
    // Automatic Variable Declarations
    // Conditions
    if (testConds) {
        if (!((UnitAbilityExists(EventUnit(), "DummyUnloadAbil") == true))) {
            return false;
        }
    }

    // Actions
    if (!runActions) {
        return true;
    }

    if ((lib74A68E34_gf_GeneralTransportHasHeroic(EventUnit()) == true)) {
        TechTreeAbilityAllow(UnitGetOwner(EventUnit()), AbilityCommand("DummyUnloadAbil", 0), true);
    }
    else {
        TechTreeAbilityAllow(UnitGetOwner(EventUnit()), AbilityCommand("DummyUnloadAbil", 0), false);
    }
    return true;
}

