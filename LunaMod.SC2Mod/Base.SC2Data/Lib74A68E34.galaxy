bool lib74A68E34_InitLib_completed = false;

void lib74A68E34_InitLib () {
    if (lib74A68E34_InitLib_completed) {
        return;
    }

    lib74A68E34_InitLib_completed = true;

    lib74A68E34_InitLibraries();
    lib74A68E34_InitCustomScript();
    lib74A68E34_InitTriggers();
}

