//--------------------------------------------------------------------------------------------------
// Trigger: ArtanisMothershipWarpHaste
//--------------------------------------------------------------------------------------------------
bool lib74A68E34_gt_ArtanisMothershipWarpHaste_Func (bool testConds, bool runActions) {
    // Automatic Variable Declarations
    // Conditions
    if (testConds) {
        if (!((TechTreeUpgradeCount(EventPlayer(), "MasteryArtanisSoAPowerFieldHaste", c_techCountCompleteOnly) > 0))) {
            return false;
        }

        if (!((UnitGetType(EventUnitProgressUnit()) == "MothershipArtanis"))) {
            return false;
        }
    }

    // Actions
    if (!runActions) {
        return true;
    }

    UnitBehaviorAdd(EventUnitProgressUnit(), "MasteryArtanisSoAPowerFieldHaste_Target", EventUnit(), 1);
    return true;
}

//--------------------------------------------------------------------------------------------------
void lib74A68E34_gt_ArtanisMothershipWarpHaste_Init () {
    lib74A68E34_gt_ArtanisMothershipWarpHaste = TriggerCreate("lib74A68E34_gt_ArtanisMothershipWarpHaste_Func");
    TriggerAddEventUnitTrainProgress(lib74A68E34_gt_ArtanisMothershipWarpHaste, null, c_unitProgressStageComplete);
}

void lib74A68E34_InitTriggers () {
    lib74A68E34_gt_ExtraUpgrades_Init();
    lib74A68E34_gt_ApplyCommanderRewards_Init();
    lib74A68E34_gt_ActivateCommanderTriggers_Init();
    lib74A68E34_gt_ArtanisMothershipWarpHaste_Init();
}

