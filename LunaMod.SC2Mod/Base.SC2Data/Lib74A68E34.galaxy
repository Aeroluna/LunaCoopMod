// Custom Script
//--------------------------------------------------------------------------------------------------
// Custom Script: ApplyVoicePack
//--------------------------------------------------------------------------------------------------
void voicepack_apply(string reward_id, int player)
{
    int i;
    int count;
    string tmp;
    count = CatalogFieldValueCount(c_gameCatalogReward, reward_id, "ReplacementArray", c_playerAny);
    for (i = 0; i < count; i += 1) {
        tmp = "ReplacementArray[" + IntToString(i) + "]";
        CatalogLinkReplace(
            player,
            c_gameCatalogSound,
            CatalogFieldValueGet(c_gameCatalogReward, reward_id, tmp + ".From", c_playerAny),
            CatalogFieldValueGet(c_gameCatalogReward, reward_id, tmp + ".To", c_playerAny)
        );
    }
}

void lib74A68E34_InitCustomScript () {
}

