//--------------------------------------------------------------------------------------------------
// Trigger: RaynorPrestigeMercenaryLaunch
//--------------------------------------------------------------------------------------------------
bool lib74A68E34_gt_RaynorPrestigeMercenaryLaunch_Func (bool testConds, bool runActions) {
    // Variable Declarations
    unit lv_compound;
    point lv_gatherPoint;
    unitgroup lv_patrol;

    // Automatic Variable Declarations
    // Variable Initialization
    lv_compound = EventPlayerEffectUsedUnit(c_effectUnitCaster);
    lv_patrol = UnitGroupEmpty();

    // Actions
    if (!runActions) {
        return true;
    }

    lv_gatherPoint = UnitRallyPointTargetPoint(lv_compound, 1, 1);
    if ((lv_gatherPoint == null)) {
        lv_gatherPoint = UnitGetPosition(lv_compound);
    }

    while ((UnitBehaviorCount(lv_compound, "HireMercMarine") > 0)) {
        UnitBehaviorRemove(lv_compound, "HireMercMarine", 1);
        libNtve_gf_CreateUnitsWithDefaultFacing(1, "WarPig", 0, EventPlayerEffectUsedUnitOwner(c_effectPlayerTarget), RegionRandomPoint(RegionCircle(lv_gatherPoint, 4.0)));
        UnitBehaviorAdd(UnitLastCreated(), "MercCompoundMercenary", lv_compound, 1);
        UnitSetCustomValue(UnitLastCreated(), lib74A68E34_gv_raynorPrestigeMercenaryRallyX, PointGetX(lv_gatherPoint));
        UnitSetCustomValue(UnitLastCreated(), lib74A68E34_gv_raynorPrestigeMercenaryRallyY, PointGetY(lv_gatherPoint));
        UnitCreateEffectUnit(lv_compound, "MercGroundDrop", UnitLastCreated());
        UnitGroupAdd(lv_patrol, UnitLastCreated());
        Wait(0.1, c_timeGame);
    }
    while ((UnitBehaviorCount(lv_compound, "HireMercFirebat") > 0)) {
        UnitBehaviorRemove(lv_compound, "HireMercFirebat", 1);
        libNtve_gf_CreateUnitsWithDefaultFacing(1, "DevilDog", 0, EventPlayerEffectUsedUnitOwner(c_effectPlayerTarget), RegionRandomPoint(RegionCircle(lv_gatherPoint, 4.0)));
        UnitBehaviorAdd(UnitLastCreated(), "MercCompoundMercenary", lv_compound, 1);
        UnitSetCustomValue(UnitLastCreated(), lib74A68E34_gv_raynorPrestigeMercenaryRallyX, PointGetX(lv_gatherPoint));
        UnitSetCustomValue(UnitLastCreated(), lib74A68E34_gv_raynorPrestigeMercenaryRallyY, PointGetY(lv_gatherPoint));
        UnitCreateEffectUnit(lv_compound, "MercGroundDrop", UnitLastCreated());
        UnitGroupAdd(lv_patrol, UnitLastCreated());
        Wait(0.1, c_timeGame);
    }
    while ((UnitBehaviorCount(lv_compound, "HireMercMarauder") > 0)) {
