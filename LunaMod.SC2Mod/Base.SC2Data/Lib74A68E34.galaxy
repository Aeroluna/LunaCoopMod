//--------------------------------------------------------------------------------------------------
// Trigger: ActivateCommanderTriggers
//--------------------------------------------------------------------------------------------------
bool lib74A68E34_gt_ActivateCommanderTriggers_Func (bool testConds, bool runActions) {
    // Variable Declarations
    string lv_playerCommander;
    int lv_player;

    // Automatic Variable Declarations
    playergroup auto00AA9AB2_g;
    string auto560DABDD_val;

    // Variable Initialization

    // Actions
    if (!runActions) {
        return true;
    }

    auto00AA9AB2_g = libCOOC_gf_HumanPlayers();
    lv_player = -1;
    while (true) {
        lv_player = PlayerGroupNextPlayer(auto00AA9AB2_g, lv_player);
        if (lv_player < 0) { break; }
        lv_playerCommander = libCOOC_gf_ActiveCommanderForPlayer(lv_player);
        auto560DABDD_val = lv_playerCommander;
        if (auto560DABDD_val == "TerranRaynor") {
            TriggerEnable(lib74A68E34_gt_RaynorHyperionWeaponSwitch, true);
        }
        else if (auto560DABDD_val == "ProtossArtanis") {
            TriggerEnable(lib74A68E34_gt_ArtanisMothershipWarpHaste, true);
            if ((TechTreeUpgradeCount(lv_player, "CommanderPrestigeArtanisPowerField", c_techCountCompleteOnly) == 1)) {
                TriggerEnable(lib74A68E34_gt_ArtanisPowerFieldPrestigePylon, true);
            }

        }
        else if (auto560DABDD_val == "ZergKerrigan") {
            TriggerEnable(lib74A68E34_gt_GeneralNydusUnloadHero, true);
        }
        else if (auto560DABDD_val == "ZergZagara") {
            TriggerEnable(lib74A68E34_gt_ZagaraSwarmLocusSetupQueen, true);
            TriggerEnable(lib74A68E34_gt_ZagaraSwarmLocusTryCreepTumor, true);
            TriggerEnable(lib74A68E34_gt_ZagaraSwarmLocusRoachScale, true);
            TriggerEnable(lib74A68E34_gt_ZagaraSwarmLocusSeekDestroy, true);
            TriggerEnable(lib74A68E34_gt_ZagaraSwarmLocusCopyBehavior, true);
            lib74A68E34_gf_ZagaraRoachCorpserMasteryHealth(lv_player);
        }
        else if (auto560DABDD_val == "ProtossKarax") {
            lib74A68E34_gf_KaraxExtraUnitVitalMastery(lv_player);
            lib74A68E34_gf_KaraxEnable20(lv_player);
        }
        else if (auto560DABDD_val == "ProtossVorazun") {
            TriggerEnable(lib74A68E34_gt_VorazunShadowArchonGender, true);
        }
        else if (auto560DABDD_val == "ZergAbathur") {
            TriggerEnable(lib74A68E34_gt_GeneralNydusUnloadHero, true);
        }
        else if (auto560DABDD_val == "TerranTychus") {
            lib74A68E34_gf_TychusEnableUIReorder(lv_player);
        }
        else {
        }
    }
    return true;
}

