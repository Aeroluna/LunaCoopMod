                PlayerGroupAdd(lib01833E95_gv_aF_SlimUI_PlayerGroup, lp_player);
                UISetFrameVisible(PlayerGroupSingle(lp_player), c_syncFrameTypeConsolePanel, false);
                DialogControlSendAnimationEvent(DialogControlLastCreated(), PlayerGroupSingle(lp_player), "SlimUI_On");
                UIDisplayMessage(PlayerGroupSingle(lp_player), c_messageAreaSubtitle, StringExternal("Param/Value/lib_74A68E34_24A79B5F"));
            }
            else {
                PlayerGroupRemove(lib01833E95_gv_aF_SlimUI_PlayerGroup, lp_player);
                UISetFrameVisible(PlayerGroupSingle(lp_player), c_syncFrameTypeConsolePanel, true);
                DialogControlSendAnimationEvent(DialogControlLastCreated(), PlayerGroupSingle(lp_player), "SlimUI_Off");
                UIDisplayMessage(PlayerGroupSingle(lp_player), c_messageAreaSubtitle, StringExternal("Param/Value/lib_74A68E34_35E50223"));
            }
        }
    }
}

