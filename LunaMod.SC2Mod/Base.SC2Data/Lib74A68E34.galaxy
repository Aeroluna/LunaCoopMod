//--------------------------------------------------------------------------------------------------
// Trigger: AbathurBiomassPickupLocustCheck
//--------------------------------------------------------------------------------------------------
bool lib74A68E34_gt_AbathurBiomassPickupLocustCheck_Func (bool testConds, bool runActions) {
    // Variable Declarations
    unit lv_swarmhost;
    unit lv_target;
    unit lv_biomass;

    // Automatic Variable Declarations
    // Variable Initialization
    lv_target = EventPlayerEffectUsedUnit(c_effectUnitTarget);
    lv_biomass = EventPlayerEffectUsedUnit(c_effectUnitCaster);

    // Actions
    if (!runActions) {
        return true;
    }

    if ((UnitHasBehavior2(lv_target, "LocustTimedLife") == true)) {
        lv_swarmhost = UnitBehaviorEffectUnit(lv_target, "LocustTimedLife", c_effectUnitCaster, 0);
        if ((UnitHasBehavior2(lv_swarmhost, "BiomassMaxedMarker") == false) && ((UnitGetType(lv_swarmhost) == "SwarmHostSplitB") || (UnitGetType(lv_swarmhost) == "SwarmHostSplitBBurrowed") || (UnitGetType(lv_swarmhost) == "SwarmHostMP") || (UnitGetType(lv_swarmhost) == "SwarmHostBurrowedMP"))) {
            UnitCreateEffectUnit(lv_biomass, "BiomassPickupDummy", lv_swarmhost);
        }
        else {
            UnitBehaviorAdd(lv_target, "NoBiomassPickup", lv_target, 1);
        }
    }
    else {
        UnitCreateEffectUnit(lv_biomass, "BiomassPickupDummy", lv_target);
    }
    return true;
}

