//--------------------------------------------------------------------------------------------------
// Trigger: ZagaraSwarmLocusSetupQueen
//--------------------------------------------------------------------------------------------------
bool lib74A68E34_gt_ZagaraSwarmLocusSetupQueen_Func (bool testConds, bool runActions) {
    // Variable Declarations
    unitgroup lv_nearbyCreepTumors;

    // Automatic Variable Declarations
    // Variable Initialization
    lv_nearbyCreepTumors = UnitGroupEmpty();

    // Conditions
    if (testConds) {
        if (!((UnitGetType(EventUnit()) == "QueenCoop"))) {
            return false;
        }
    }

    // Actions
    if (!runActions) {
        return true;
    }

    UnitSetPropertyFixed(EventUnit(), c_unitPropEnergyPercent, 100.0);
    UnitIssueOrder(EventUnit(), OrderSetAutoCast(AbilityCommand("Transfusion", 0), true), c_orderQueueReplace);
    UnitBehaviorAdd(EventUnit(), "SwarmLocusTryCreepTumor", EventUnit(), 1);
    return true;
