//--------------------------------------------------------------------------------------------------
// Trigger: RaynorPrestigeMercenaryReset
//--------------------------------------------------------------------------------------------------
bool lib74A68E34_gt_RaynorPrestigeMercenaryReset_Func (bool testConds, bool runActions) {
    // Variable Declarations
    unit lv_compound;
    int lv_minerals;
    int lv_vespene;

    // Automatic Variable Declarations
    // Variable Initialization
    lv_compound = EventPlayerEffectUsedUnit(c_effectUnitCaster);

    // Actions
    if (!runActions) {
        return true;
    }

    lv_minerals += (UnitBehaviorCount(lv_compound, "HireMercMarine") * UnitTypeGetCost("WarPig", c_unitCostMinerals));
    UnitBehaviorRemove(lv_compound, "HireMercMarine", 999);
    lv_minerals += (UnitBehaviorCount(lv_compound, "HireMercFirebat") * UnitTypeGetCost("DevilDog", c_unitCostMinerals));
    lv_vespene += (UnitBehaviorCount(lv_compound, "HireMercFirebat") * UnitTypeGetCost("DevilDog", c_unitCostVespene));
    UnitBehaviorRemove(lv_compound, "HireMercFirebat", 999);
    lv_minerals += (UnitBehaviorCount(lv_compound, "HireMercMarauder") * UnitTypeGetCost("HammerSecurity", c_unitCostMinerals));
    lv_vespene += (UnitBehaviorCount(lv_compound, "HireMercMarauder") * UnitTypeGetCost("HammerSecurity", c_unitCostVespene));
    UnitBehaviorRemove(lv_compound, "HireMercMarauder", 999);
    lv_minerals += (UnitBehaviorCount(lv_compound, "HireMercMedic") * UnitTypeGetCost("MercMedic", c_unitCostMinerals));
    lv_vespene += (UnitBehaviorCount(lv_compound, "HireMercMedic") * UnitTypeGetCost("MercMedic", c_unitCostVespene));
    UnitBehaviorRemove(lv_compound, "HireMercMedic", 999);
    lv_minerals += (UnitBehaviorCount(lv_compound, "HireMercSiegeTank") * UnitTypeGetCost("SiegeBreaker", c_unitCostMinerals));
    lv_vespene += (UnitBehaviorCount(lv_compound, "HireMercSiegeTank") * UnitTypeGetCost("SiegeBreaker", c_unitCostVespene));
    UnitBehaviorRemove(lv_compound, "HireMercSiegeTank", 999);
    lv_minerals += (UnitBehaviorCount(lv_compound, "HireMercViking") * UnitTypeGetCost("HelsAngelFighter", c_unitCostMinerals));
    lv_vespene += (UnitBehaviorCount(lv_compound, "HireMercViking") * UnitTypeGetCost("HelsAngelFighter", c_unitCostVespene));
    UnitBehaviorRemove(lv_compound, "HireMercViking", 999);
    lv_minerals += (UnitBehaviorCount(lv_compound, "HireMercBanshee") * UnitTypeGetCost("DuskWing", c_unitCostMinerals));
    lv_vespene += (UnitBehaviorCount(lv_compound, "HireMercBanshee") * UnitTypeGetCost("DuskWing", c_unitCostVespene));
    UnitBehaviorRemove(lv_compound, "HireMercBanshee", 999);
    lv_minerals += (UnitBehaviorCount(lv_compound, "HireMercBattlecruiser") * UnitTypeGetCost("DukesRevenge", c_unitCostMinerals));
    lv_vespene += (UnitBehaviorCount(lv_compound, "HireMercBattlecruiser") * UnitTypeGetCost("DukesRevenge", c_unitCostVespene));
    UnitBehaviorRemove(lv_compound, "HireMercBattlecruiser", 999);
    PlayerModifyPropertyInt(EventPlayerEffectUsedUnitOwner(c_effectPlayerTarget), c_playerPropMinerals, c_playerPropOperAdd, lv_minerals);
    PlayerModifyPropertyInt(EventPlayerEffectUsedUnitOwner(c_effectPlayerTarget), c_playerPropVespene, c_playerPropOperAdd, lv_vespene);
    if (((lv_minerals > 0) || (lv_vespene > 0))) {
        if ((lv_minerals > 0) && (lv_vespene > 0)) {
            TextExpressionSetToken("Param/Expression/lib_74A68E34_2DFFF43D", "Minerals", IntToText(lv_minerals));
            TextExpressionSetToken("Param/Expression/lib_74A68E34_2DFFF43D", "Vespene", IntToText(lv_vespene));
            TextTagCreate(TextExpressionAssemble("Param/Expression/lib_74A68E34_2DFFF43D"), 24, UnitGetPosition(EventPlayerEffectUsedUnit(c_effectUnitCaster)), 3.0, true, false, PlayerGroupSingle(EventPlayerEffectUsedUnitOwner(c_effectPlayerTarget)));
            TextTagSetVelocity(TextTagLastCreated(), 0.5, 90.0);
        }
        else {
            TextExpressionSetToken("Param/Expression/lib_74A68E34_A164617D", "Minerals", IntToText(lv_minerals));
            TextTagCreate(TextExpressionAssemble("Param/Expression/lib_74A68E34_A164617D"), 24, UnitGetPosition(EventPlayerEffectUsedUnit(c_effectUnitCaster)), 3.0, true, false, PlayerGroupSingle(EventPlayerEffectUsedUnitOwner(c_effectPlayerTarget)));
            TextTagSetVelocity(TextTagLastCreated(), 0.5, 90.0);
        }
        Wait(1.5, c_timeGame);
        TextTagDestroy(TextTagLastCreated());
    }

    return true;
}

