    // Variable Declarations
    unit lv_target;
    string lv_behavior;

    // Automatic Variable Declarations
    unit auto3C6F4975_u;
    int auto3C6F4975_i;

    // Variable Initialization
    lv_target = EventPlayerEffectUsedUnit(c_effectUnitTarget);

    // Actions
    if (!runActions) {
        return true;
    }

    auto3C6F4975_u = lv_target;
    auto3C6F4975_i = 1;
    for ( ; auto3C6F4975_i <= UnitBehaviorCountAll(auto3C6F4975_u) ; auto3C6F4975_i += BoolToInt(lv_behavior == UnitBehaviorGet(auto3C6F4975_u, auto3C6F4975_i)) ) {
        lv_behavior = UnitBehaviorGet(auto3C6F4975_u, auto3C6F4975_i);
        if ((UnitBehaviorHasFlag(lv_behavior, c_unitBehaviorFlagRestorable) == true) && (libNtve_gf_PlayerIsEnemy(EventPlayerEffectUsedUnitOwner(c_effectPlayerCaster), UnitBehaviorEffectPlayer(lv_target, lv_behavior, c_effectPlayerCaster, 0), libNtve_ge_PlayerRelation_Enemy) == true)) {
            UnitBehaviorRemove(lv_target, lv_behavior, 65535);
        }

    }
    return true;
}

