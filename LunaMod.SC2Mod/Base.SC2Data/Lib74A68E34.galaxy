bool lib74A68E34_gt_DehakaPrestigeArmy_Func (bool testConds, bool runActions) {
    // Automatic Variable Declarations
    string auto79CA2346_val;

    // Conditions
    if (testConds) {
        if (!(((UnitGetType(EventUnitCreatedUnit()) == "DehakaRavasaur") || (UnitGetType(EventUnitCreatedUnit()) == "DehakaRoachLevel3") || (UnitGetType(EventUnitCreatedUnit()) == "DehakaGuardianFightMorph") || (UnitGetType(EventUnitCreatedUnit()) == "DehakaMutaliskLevel3FightMorph") || (UnitGetType(EventUnitCreatedUnit()) == "ImpalerDehaka") || (UnitGetType(EventUnitCreatedUnit()) == "DehakaPrimalSwarmHost") || (UnitGetType(EventUnitCreatedUnit()) == "DehakaUltraliskLevel3")))) {
            return false;
        }
    }

    // Actions
    if (!runActions) {
        return true;
    }

    UnitBehaviorAddPlayer(EventUnitCreatedUnit(), "CommanderPrestigeDehakaArmySupply", EventPlayer(), (UnitGetPropertyInt(EventUnitCreatedUnit(), c_unitPropSuppliesUsed, c_unitPropNormal) * 1));
    Wait(8.0, c_timeGame);
    if ((UnitIsAlive(EventUnitCreatedUnit()) == false)) {
        return true;
    }

    libNtve_gf_CreateUnitsWithDefaultFacing(1, UnitGetType(EventUnitCreatedUnit()), c_unitCreateIgnorePlacement | c_unitCreateIgnoreBirth, EventPlayer(), UnitGetPosition(EventUnitCreatedUnit()));
    auto79CA2346_val = UnitGetType(EventUnitCreatedUnit());
    if (auto79CA2346_val == "DehakaRavasaur") {
        UnitCreateEffectUnit(EventUnit(), "DehakaGeneRavasaurMorphSet", UnitLastCreated());
    }
    else if (auto79CA2346_val == "DehakaRoachLevel3") {
        UnitCreateEffectUnit(EventUnit(), "DehakaGeneFireRoachMorphSet", UnitLastCreated());
    }
    else if (auto79CA2346_val == "DehakaGuardianFightMorph") {
        UnitCreateEffectUnit(EventUnit(), "DehakaGeneGuardianMorphSet", UnitLastCreated());
    }
    else if (auto79CA2346_val == "DehakaMutaliskLevel3FightMorph") {
        UnitCreateEffectUnit(EventUnit(), "DehakaGeneMutaliskMorphSet", UnitLastCreated());
    }
    else if (auto79CA2346_val == "ImpalerDehaka") {
        UnitCreateEffectUnit(EventUnit(), "DehakaGeneImpalerMorphSet", UnitLastCreated());
    }
    else if (auto79CA2346_val == "DehakaPrimalSwarmHost") {
        UnitCreateEffectUnit(EventUnit(), "DehakaGeneCreeperHostMorphSet", UnitLastCreated());
    }
    else if (auto79CA2346_val == "DehakaUltraliskLevel3") {
        UnitCreateEffectUnit(EventUnit(), "DehakaGeneTyrannosaurMorphSet", UnitLastCreated());
    }
    else {
        return true;
    }
    libNtve_gf_SendActorMessageToUnit(UnitLastCreated(), "AnimPlay Birth Unburrow 0 0.000000");
    return true;
}

