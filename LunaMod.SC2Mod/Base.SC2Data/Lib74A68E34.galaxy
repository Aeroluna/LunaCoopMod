bool lib74A68E34_gt_ZagaraSwarmLocusCopyBehavior_Func (bool testConds, bool runActions) {
    // Automatic Variable Declarations
    // Conditions
    if (testConds) {
        if (!((UnitGetType(EventUnit()) != "CreepTumorQueen"))) {
            return false;
        }

        if (!((UnitHasBehavior2(EventUnit(), "SwarmLocusUnitSeekDestroy") == true))) {
            return false;
        }
    }

    // Actions
    if (!runActions) {
        return true;
    }

    UnitBehaviorAdd(EventUnitCreatedUnit(), "SwarmLocusUnitTimedLife", EventUnit(), 1);
    UnitBehaviorAdd(EventUnitCreatedUnit(), "SwarmLocusUnitSeekDestroy", EventUnit(), 1);
    return true;
}

