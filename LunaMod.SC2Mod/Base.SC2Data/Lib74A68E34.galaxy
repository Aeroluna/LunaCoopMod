    string lv_extraUpgrades;
    int lv_index;

    // Automatic Variable Declarations
    string autoC0E27C80_userType;
    int autoC0E27C80_i;
    int auto9C1173A7_ae;
    const int auto9C1173A7_ai = 1;

    // Variable Initialization

    // Actions
    if (!runActions) {
        return true;
    }

    autoC0E27C80_userType = "ExtraUpgrades";
    autoC0E27C80_i = 1;
    for ( ; autoC0E27C80_i <= UserDataInstanceCount(autoC0E27C80_userType) ; autoC0E27C80_i += 1 ) {
        lv_extraUpgrades = UserDataInstance(autoC0E27C80_userType, autoC0E27C80_i);
        if ((EventUpgradeName() == UserDataGetUpgrade("ExtraUpgrades", lv_extraUpgrades, "Source Upgrade", 1))) {
            lv_upgradeLevel = TechTreeUpgradeCount(EventPlayer(), EventUpgradeName(), c_techCountCompleteOnly);
            auto9C1173A7_ae = UserDataFieldValueCount("ExtraUpgrades", "Target Upgrades");
            lv_index = 1;
            for ( ; ( (auto9C1173A7_ai >= 0 && lv_index <= auto9C1173A7_ae) || (auto9C1173A7_ai < 0 && lv_index >= auto9C1173A7_ae) ) ; lv_index += auto9C1173A7_ai ) {
                libNtve_gf_SetUpgradeLevelForPlayer(EventPlayer(), UserDataGetUpgrade("ExtraUpgrades", lv_extraUpgrades, "Target Upgrades", lv_index), lv_upgradeLevel);
            }
            return true;
        }

    }
    return true;
}

