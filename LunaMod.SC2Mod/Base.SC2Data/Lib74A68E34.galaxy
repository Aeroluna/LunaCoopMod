            UIDisplayMessage(PlayerGroupSingle(lp_player), c_messageAreaSubtitle, StringExternal("Param/Value/lib_74A68E34_F43F2DA9"));
        }
        else {
            PlayerGroupRemove(lib01833E95_gv_aF_SlimUI_PlayerGroup, lp_player);
            TriggerEnable(lib01833E95_gt_AF_SlimUI_Delayed, false);
            UIDisplayMessage(PlayerGroupSingle(lp_player), c_messageAreaSubtitle, StringExternal("Param/Value/lib_74A68E34_C25A0548"));
        }
    }
    else {
        if ((GameGetMissionTime() < 5.0)) {
