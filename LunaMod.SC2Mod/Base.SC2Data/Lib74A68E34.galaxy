//--------------------------------------------------------------------------------------------------
// Trigger: ArtanisPowerFieldPrestigePylon
//--------------------------------------------------------------------------------------------------
bool lib74A68E34_gt_ArtanisPowerFieldPrestigePylon_Func (bool testConds, bool runActions) {
    // Automatic Variable Declarations
    // Actions
    if (!runActions) {
        return true;
    }

    if ((UnitGetType(EventUnitCreatedUnit()) == "SOAPylonPowerUnit")) {
        UnitBehaviorRemovePlayer(EventUnitCreatedUnit(), "SOAPylonPower", 1, 1);
        UnitBehaviorAddPlayer(EventUnitCreatedUnit(), "SOAPylonPowerPrestige", 1, 1);
    }
    else if ((UnitGetType(EventUnitCreatedUnit()) == "SOAPylonPowerAllyUnit")) {
        UnitBehaviorRemovePlayer(EventUnitCreatedUnit(), "SOAPylonPowerAlly", 1, 1);
        UnitBehaviorAddPlayer(EventUnitCreatedUnit(), "SOAPylonPowerPrestigeAlly", 1, 1);
    }
    return true;
}

