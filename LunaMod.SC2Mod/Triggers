                            player,
                            c_gameCatalogSound,
                            CatalogFieldValueGet(c_gameCatalogReward, reward_id, tmp + &quot;.From&quot;, c_playerAny),
                            CatalogFieldValueGet(c_gameCatalogReward, reward_id, tmp + &quot;.To&quot;, c_playerAny)
                        );
                    }
                }
            </ScriptCode>
