                void voicepack_apply(string reward_id, int player)
                {
                    int i;
                    int count;
                    string tmp;
                    count = CatalogFieldValueCount(c_gameCatalogReward, reward_id, &quot;ReplacementArray&quot;, c_playerAny);
                    for (i = 0; i &lt; count; i += 1) {
                        tmp = &quot;ReplacementArray[&quot; + IntToString(i) + &quot;]&quot;;
