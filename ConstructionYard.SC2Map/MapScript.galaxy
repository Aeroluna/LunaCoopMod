void gt_APCCleanSCV_Init () {
    gt_APCCleanSCV = TriggerCreate("gt_APCCleanSCV_Func");
    TriggerEnable(gt_APCCleanSCV, false);
    TriggerAddEventTimePeriodic(gt_APCCleanSCV, 10.0, c_timeGame);
}

//--------------------------------------------------------------------------------------------------
// Trigger: APC Disable Script Control
//--------------------------------------------------------------------------------------------------
bool gt_APCDisableScriptControl_Func (bool testConds, bool runActions) {
    // Variable Declarations
    unit lv_hut;

    // Automatic Variable Declarations
    // Variable Initialization

    // Conditions
    if (testConds) {
        if (!((libCOMI_gf_GameIsOver() == false))) {
            return false;
        }

        if (!((UnitGetType(EventUnit()) == "ColonistTransport"))) {
            return false;
        }
    }

    // Actions
    if (!runActions) {
        return true;
    }

    if ((UnitGetType(EventUnitCargo()) == "ColonistSCV")) {
        UnitIssueOrder(EventUnitCargo(), OrderTargetingPoint(AbilityCommand("move", 0), lib74A68E34_gf_VaryPosition(UnitGetPosition(EventUnitCargo()), 4.0)), c_orderQueueReplace);
    }
    else if ((UnitGetType(EventUnitCargo()) == "Marine")) {
        UnitIssueOrder(EventUnitCargo(), OrderTargetingPoint(AbilityCommand("attack", 0), lib74A68E34_gf_VaryPosition(UnitGetPosition(EventUnitCargo()), 4.0)), c_orderQueueReplace);
    }
    else if (((UnitGetType(EventUnitCargo()) == "ColonistFemale") || (UnitGetType(EventUnitCargo()) == "Colonist"))) {
        lv_hut = UnitGroupRandomUnit(UnitGroup("NovaColonistHut", gv_pLAYER_05_COLONISTS, RegionCircle(UnitGetPosition(EventUnitCargo()), 20.0), UnitFilter(0, 0, 0, 0), 0), c_unitCountAlive);
        UnitIssueOrder(EventUnitCargo(), OrderTargetingUnit(null, lv_hut), c_orderQueueReplace);
    }
    return true;
}

