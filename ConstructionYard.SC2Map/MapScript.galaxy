//--------------------------------------------------------------------------------------------------
// Trigger: Attack Waves
//--------------------------------------------------------------------------------------------------
bool gt_AttackWaves_Func (bool testConds, bool runActions) {
    // Automatic Variable Declarations
    // Actions
    if (!runActions) {
        return true;
    }

    gf_WaitForAITime((3.0 * 60.0));
    gf_AttackBase(libCOMI_ge_CoopAIAttackWaveBuckets__1Smallest, libCOMI_ge_CoopAITechLevelBuckets__1Early, 0, 0);
    gf_WaitForAITime((4.0 * 60.0));
    gf_APCLaunch(libCOMI_ge_CoopAIAttackWaveBuckets__1Smallest, libCOMI_ge_CoopAITechLevelBuckets__2EarlyMid);
    TechTreeAbilityAllow(gv_pLAYER_05_COLONISTS, AbilityCommand("BarracksTrain", 0), true);
    gf_WaitForAITime((7.0 * 60.0));
    gf_PickRandomCampForAttack(libCOMI_ge_CoopAIAttackWaveBuckets__2Smaller, libCOMI_ge_CoopAITechLevelBuckets__2EarlyMid, libCOMI_gf_DifficultyValueInt2(libCOMI_gf_GetMissionDifficulty(), 0, 0, 1, 1, 0, 0), 0);
    gf_WaitForAITime((8.0 * 60.0));
    gf_APCLaunch(libCOMI_ge_CoopAIAttackWaveBuckets__2Smaller, libCOMI_ge_CoopAITechLevelBuckets__3Mid);
    gf_WaitForAITime((10.0 * 60.0));
    gf_PickRandomCampForAttack(libCOMI_ge_CoopAIAttackWaveBuckets__2Smaller, libCOMI_ge_CoopAITechLevelBuckets__2EarlyMid, 0, 0);
    gf_WaitForAITime((11.0 * 60.0));
    TriggerExecute(gt_BonusRevealTransmissionQ, true, false);
    gf_WaitForAITime((12.0 * 60.0));
    gf_APCLaunch(libCOMI_ge_CoopAIAttackWaveBuckets__3Small, libCOMI_ge_CoopAITechLevelBuckets__4LateMid);
    AISetDifficulty(gv_pLAYER_03_ENEMY, c_diffEnableDangerMap, true);
    AISetDifficulty(gv_pLAYER_04_ENEMY, c_diffEnableDangerMap, true);
    AISetDifficulty(gv_pLAYER_03_ENEMY, c_diffWaveAvoidDanger, true);
    AISetDifficulty(gv_pLAYER_04_ENEMY, c_diffWaveAvoidDanger, true);
    gf_WaitForAITime((14.0 * 60.0));
    gf_PickRandomCampForAttack(libCOMI_ge_CoopAIAttackWaveBuckets__3Small, libCOMI_ge_CoopAITechLevelBuckets__3Mid, 0, 0);
    gf_WaitForAITime((16.5 * 60.0));
    gf_PickRandomCampForAttack(libCOMI_ge_CoopAIAttackWaveBuckets__2Smaller, libCOMI_ge_CoopAITechLevelBuckets__4LateMid, libCOMI_gf_DifficultyValueInt2(libCOMI_gf_GetMissionDifficulty(), 0, 0, 1, 1, 0, 0), 0);
    gf_WaitForAITime((17.0 * 60.0));
    gf_APCLaunch(libCOMI_ge_CoopAIAttackWaveBuckets__4Medium, libCOMI_ge_CoopAITechLevelBuckets__5Late);
    gf_WaitForAITime((19.0 * 60.0));
    gf_AttackBase(libCOMI_ge_CoopAIAttackWaveBuckets__5Large, libCOMI_ge_CoopAITechLevelBuckets__5Late, 0, libCOMI_gf_DifficultyValueInt2(libCOMI_gf_GetMissionDifficulty(), 0, 0, 1, 1, 0, 0));
    gf_WaitForAITime((21.0 * 60.0));
    gf_APCLaunch(libCOMI_ge_CoopAIAttackWaveBuckets__5Large, libCOMI_ge_CoopAITechLevelBuckets_TechLevel06);
    gf_WaitForAITime((23.0 * 60.0));
    gf_PickRandomCampForAttack(libCOMI_ge_CoopAIAttackWaveBuckets__4Medium, libCOMI_ge_CoopAITechLevelBuckets__4LateMid, libCOMI_gf_DifficultyValueInt2(libCOMI_gf_GetMissionDifficulty(), 0, 0, 1, 1, 0, 0), 0);
    gf_WaitForAITime((25.0 * 60.0));
    gf_PickRandomCampForAttack(libCOMI_ge_CoopAIAttackWaveBuckets__3Small, libCOMI_ge_CoopAITechLevelBuckets__4LateMid, libCOMI_gf_DifficultyValueInt2(libCOMI_gf_GetMissionDifficulty(), 1, 1, 2, 2, 0, 0), 0);
    gf_WaitForAITime((26.0 * 60.0));
    gf_APCLaunch(libCOMI_ge_CoopAIAttackWaveBuckets__6Larger, libCOMI_ge_CoopAITechLevelBuckets_TechLevel07);
    gf_WaitForAITime((27.0 * 60.0));
    gf_AttackBase(libCOMI_ge_CoopAIAttackWaveBuckets__6Larger, libCOMI_ge_CoopAITechLevelBuckets_TechLevel06, libCOMI_gf_DifficultyValueInt2(libCOMI_gf_GetMissionDifficulty(), 1, 1, 2, 2, 0, 0), libCOMI_gf_DifficultyValueInt2(libCOMI_gf_GetMissionDifficulty(), 1, 1, 2, 2, 0, 0));
    while ((libCOMI_gf_GameIsOver() == false)) {
        Wait((1.0 * 60.0), c_timeAI);
        gf_APCLaunch(libCOMI_ge_CoopAIAttackWaveBuckets__6Larger, libCOMI_ge_CoopAITechLevelBuckets_TechLevel07);
        Wait((1.0 * 60.0), c_timeAI);
        gf_PickRandomCampForAttack(libCOMI_ge_CoopAIAttackWaveBuckets__7Largest, libCOMI_ge_CoopAITechLevelBuckets_TechLevel07, libCOMI_gf_DifficultyValueInt2(libCOMI_gf_GetMissionDifficulty(), 1, 1, 2, 2, 0, 0), libCOMI_gf_DifficultyValueInt2(libCOMI_gf_GetMissionDifficulty(), 0, 0, 1, 1, 0, 0));
    }
    return true;
}

