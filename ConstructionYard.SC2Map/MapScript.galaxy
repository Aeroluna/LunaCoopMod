bool auto_gf_RecallUnit_TriggerFunc (bool testConds, bool runActions) {
    unit lp_unit = auto_gf_RecallUnit_lp_unit;

    // Automatic Variable Declarations
    // Implementation
    while ((UnitIsAlive(lp_unit) == true) && (DistanceBetweenPoints(UnitGetPosition(lp_unit), PointFromId(2071421794)) > 1.0)) {
        UnitIssueOrder(lp_unit, OrderTargetingPoint(AbilityCommand("move", 0), PointFromId(2071421794)), c_orderQueueReplace);
        Wait(1.0, c_timeGame);
    }
    UnitRemove(lp_unit);
    return true;
}

