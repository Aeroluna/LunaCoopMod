//--------------------------------------------------------------------------------------------------
// Trigger: Defeat Primary Objective Failed
//--------------------------------------------------------------------------------------------------
bool gt_DefeatPrimaryObjectiveFailed_Func (bool testConds, bool runActions) {
    // Automatic Variable Declarations
    unitgroup autoC51EF2A1_g;
    int autoC51EF2A1_u;
    unit autoC51EF2A1_var;
    playergroup auto011FDCCB_g;
    int auto011FDCCB_var;

    // Conditions
    if (testConds) {
        if (!((libCOMI_gf_GameIsOver() == false))) {
            return false;
        }

        if (!((TriggerIsEnabled(TriggerGetCurrent()) == true))) {
            return false;
        }
    }

    // Actions
    if (!runActions) {
        return true;
    }

    TriggerEnable(TriggerGetCurrent(), false);
    libCOMI_gf_GameOver(libCOMI_ge_CampaignMissionGameResultType_Defeat);
    TransmissionClearAll();
    TriggerQueuePause(true);
    TriggerQueueClear(c_triggerQueueRemove);
    libCOMI_gf_SendMissionTransmission("DefeatCY", false, -1);
    libCOMI_gf_CinematicModeCampaign(true, 1.5, true);
    TriggerExecute(gt_ObjectiveDontDestroyCampsFailed, true, false);
    TriggerExecute(gt_ObjectiveSixCampsFailed, true, false);
    libCOMI_gf_DisplayCampaignMessage(PlayerGroupAll(), libCOMI_ge_CampaignMessageType_MissionFailed, StringExternal("Param/Value/79231964"), libCOMI_ge_CampaignMessageFormatNotFormat_FormatMessage);
    Wait(2.0, c_timeReal);
    autoC51EF2A1_g = UnitGroup(null, c_playerAny, RegionEntireMap(), UnitFilter(0, 0, (1 << c_targetFilterMissile), (1 << (c_targetFilterDead - 32)) | (1 << (c_targetFilterHidden - 32))), 0);
    autoC51EF2A1_u = UnitGroupCount(autoC51EF2A1_g, c_unitCountAll);
    for (;; autoC51EF2A1_u -= 1) {
        autoC51EF2A1_var = UnitGroupUnitFromEnd(autoC51EF2A1_g, autoC51EF2A1_u);
        if (autoC51EF2A1_var == null) { break; }
        UnitIssueOrder(autoC51EF2A1_var, Order(AbilityCommand("stop", 0)), c_orderQueueReplace);
    }
    libNtve_gf_SetAlliance(gv_pLAYER_01_USER, gv_pLAYER_03_ENEMY, libNtve_ge_AllianceSetting_Ally);
    libNtve_gf_SetAlliance(gv_pLAYER_01_USER, gv_pLAYER_04_ENEMY, libNtve_ge_AllianceSetting_Ally);
    libNtve_gf_SetAlliance(gv_pLAYER_02_USER, gv_pLAYER_03_ENEMY, libNtve_ge_AllianceSetting_Ally);
    libNtve_gf_SetAlliance(gv_pLAYER_02_USER, gv_pLAYER_04_ENEMY, libNtve_ge_AllianceSetting_Ally);
    libNtve_gf_SetAlliance(gv_pLAYER_03_ENEMY, gv_pLAYER_01_USER, libNtve_ge_AllianceSetting_Ally);
    libNtve_gf_SetAlliance(gv_pLAYER_03_ENEMY, gv_pLAYER_02_USER, libNtve_ge_AllianceSetting_Ally);
    libNtve_gf_SetAlliance(gv_pLAYER_04_ENEMY, gv_pLAYER_01_USER, libNtve_ge_AllianceSetting_Ally);
    libNtve_gf_SetAlliance(gv_pLAYER_04_ENEMY, gv_pLAYER_02_USER, libNtve_ge_AllianceSetting_Ally);
    auto011FDCCB_g = libCOOC_gf_HumanPlayers();
    auto011FDCCB_var = -1;
    while (true) {
        auto011FDCCB_var = PlayerGroupNextPlayer(auto011FDCCB_g, auto011FDCCB_var);
        if (auto011FDCCB_var < 0) { break; }
        CameraApplyInfo(auto011FDCCB_var, CameraInfoDefault(), 2.0, -1, 10.0, false);
        CameraPan(auto011FDCCB_var, gv_defeatPan, 2.0, 0, 10, false);
    }
    Wait(4.0, c_timeReal);
    UISetCursorVisible(PlayerGroupAll(), true);
    TriggerExecute(gt_Defeat, true, false);
    return true;
}

