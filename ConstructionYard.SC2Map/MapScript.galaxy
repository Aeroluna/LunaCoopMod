    TriggerEnable(gt_APCMarineRespawn, false);
    TriggerAddEventTimePeriodic(gt_APCMarineRespawn, 10.0, c_timeGame);
}

//--------------------------------------------------------------------------------------------------
// Trigger: APC Clean SCV
//--------------------------------------------------------------------------------------------------
bool gt_APCCleanSCV_Func (bool testConds, bool runActions) {
    // Variable Declarations
    int lv_marinecount;
    unitgroup lv_scvs;

    // Automatic Variable Declarations
    const int auto0714DAC6_ae = 2;
    int auto0714DAC6_var;

    // Variable Initialization
    lv_scvs = UnitGroupEmpty();

    // Conditions
    if (testConds) {
        if (!((libCOMI_gf_PlayerInCinematicModeCampaign() == false))) {
            return false;
        }

        if (!((libCOMI_gf_GameIsOver() == false))) {
            return false;
        }
    }

    // Actions
    if (!runActions) {
        return true;
    }

    lv_marinecount = ((gv_aPCLaunchCount * 2) + 2);
    lv_marinecount = MinI(lv_marinecount, 14);
    auto0714DAC6_var = 1;
    for ( ; auto0714DAC6_var <= auto0714DAC6_ae; auto0714DAC6_var += 1 ) {
        if (((gv_bonusStatus[auto0714DAC6_var] == ge_BonusStatus_Active) || (gv_bonusStatus[auto0714DAC6_var] == ge_BonusStatus_Complete))) {
            lv_marinecount += 4;
        }

    }
    lv_scvs = UnitGroup("ColonistSCV", gv_pLAYER_05_COLONISTS, RegionEntireMap(), UnitFilter(0, 0, (1 << c_targetFilterMissile), (1 << (c_targetFilterDead - 32)) | (1 << (c_targetFilterHidden - 32))), 0);
    if ((UnitGroupCount(lv_scvs, c_unitCountAlive) > lv_marinecount)) {
        gf_RecallUnit(UnitGroupRandomUnit(lv_scvs, c_unitCountAlive));
    }

    return true;
}

