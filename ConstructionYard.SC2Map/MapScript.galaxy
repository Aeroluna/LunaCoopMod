    gt_ObjectiveDontDestroyCampsDecrease_Init();
    gt_ObjectiveDontDestroyCampsFailed_Init();
    gt_ObjectiveNorthernFacilityCreate_Init();
    gt_ObjectiveNorthernFacilityComplete_Init();
    gt_ObjectiveNorthernFacilityFailed_Init();
    gt_ObjectiveSouthernFacilityCreate_Init();
    gt_ObjectiveSouthernFacilityComplete_Init();
    gt_ObjectiveSouthernFacilityFailed_Init();
}

//--------------------------------------------------------------------------------------------------
// Map Initialization
//--------------------------------------------------------------------------------------------------
void InitMap () {
    InitLibs();
    InitGlobals();
    InitTriggers();
}
