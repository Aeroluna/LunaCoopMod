    gt_APCDisableScriptControl = TriggerCreate("gt_APCDisableScriptControl_Func");
    TriggerAddEventUnitCargo(gt_APCDisableScriptControl, null, false);
}

//--------------------------------------------------------------------------------------------------
// Trigger: APC Slow
//--------------------------------------------------------------------------------------------------
bool gt_APCSlow_Func (bool testConds, bool runActions) {
    // Automatic Variable Declarations
    // Conditions
    if (testConds) {
        if (!((libCOMI_gf_GameIsOver() == false))) {
            return false;
        }
    }

    // Actions
    if (!runActions) {
        return true;
    }

    if ((UnitBehaviorEnabled(EventUnit(), "ColonistAPCSlow") == true)) {
        UnitSetPropertyFixed(EventUnit(), c_unitPropMovementSpeed, 0.3);
        TriggerExecute(gt_APCWarningTransmissionQ, true, false);
    }
    else {
        UnitSetPropertyFixed(EventUnit(), c_unitPropMovementSpeed, UnitTypeGetProperty(UnitGetType(EventUnit()), c_unitPropMovementSpeed));
    }
    return true;
}

