    }
    else if (auto3E807AE9_val == 2) {
        libCOMI_gf_SendMissionTransmission("Intro2CY", true, -1);
    }
    else if (auto3E807AE9_val == 3) {
        libCOMI_gf_SendMissionTransmission("Intro3CY", true, -1);
    }
    else {
    }
    libCOOC_gf_SetAllSoundChannelVolumesCampaign(libCOOC_ge_VolumeChannelModeCampaign_Game);
    TriggerQueueExit();
    Wait(2.0, c_timeAI);
    TriggerExecute(gt_TipReadyQ, true, false);
