    unit lv_beacon;

    // Automatic Variable Declarations
    const int auto64DF87B4_ae = 2;
    const int auto64DF87B4_ai = 1;
    playergroup auto33E8407C_g;
    int auto33E8407C_var;

    // Variable Initialization
    lv_eventInitiationUnitFilter = UnitFilter(0, 0, 0, 0);
    lv_colonyShipCaptureTimer = TimerCreate();
    lv_capturingPlayerUnits = UnitGroupEmpty();

    // Conditions
    if (testConds) {
        if (!((libCOMI_gf_GameIsOver() == false))) {
            return false;
        }

        if (!((TriggerIsEnabled(TriggerGetCurrent()) == true))) {
            return false;
        }
    }

    // Actions
    if (!runActions) {
        return true;
    }

    lv_eventInitiationUnitFilter = UnitFilter((1 << c_targetFilterGround), 0, (1 << c_targetFilterMissile), (1 << (c_targetFilterDead - 32)) | (1 << (c_targetFilterHidden - 32)) | (1 << (c_targetFilterInvulnerable - 32)));
    lv_tankIter = 1;
    for ( ; ( (auto64DF87B4_ai >= 0 && lv_tankIter <= auto64DF87B4_ae) || (auto64DF87B4_ai < 0 && lv_tankIter >= auto64DF87B4_ae) ) ; lv_tankIter += auto64DF87B4_ai ) {
        auto33E8407C_g = libCOOC_gf_HumanPlayers();
        auto33E8407C_var = -1;
        while (true) {
            auto33E8407C_var = PlayerGroupNextPlayer(auto33E8407C_g, auto33E8407C_var);
            if (auto33E8407C_var < 0) { break; }
            if ((gv_bonusStatus[lv_tankIter] == ge_BonusStatus_Idle) && (UnitGroupCount(UnitGroup(null, auto33E8407C_var, gv_bonusBeaconRegion[lv_tankIter], lv_eventInitiationUnitFilter, 1), c_unitCountAlive) > 0)) {
                lv_colonyShipIndex = lv_tankIter;
                break;
            }

        }
        if ((lv_colonyShipIndex != 0)) {
            break;
        }

    }
    if ((lv_colonyShipIndex == 0)) {
        return true;
    }

    TimerStart(lv_colonyShipCaptureTimer, 10.0, false, c_timeGame);
    lv_beacon = gv_bonusBeacon[lv_colonyShipIndex];
    gv_bonusStatus[lv_colonyShipIndex] = ge_BonusStatus_Initiating;
    libCOUI_gf_SetUnitProgressBarValueRange(lv_beacon, 0, FixedToInt(TimerGetDuration(lv_colonyShipCaptureTimer)));
    libCOUI_gf_ShowHideUnitProgressBar(lv_beacon, true);
    while (true) {
        lv_capturingPlayerUnits = UnitGroupAlliance(gv_pLAYER_05_COLONISTS, c_unitAllianceAlly, gv_bonusBeaconRegion[lv_colonyShipIndex], lv_eventInitiationUnitFilter, 0);
        libCOUI_gf_SetUnitProgressBarProgress2(lv_beacon, FixedToInt(TimerGetRemaining(lv_colonyShipCaptureTimer)));
        libCOUI_gf_SetUnitProgressBarProgress(lv_beacon, FixedToInt(TimerGetRemaining(lv_colonyShipCaptureTimer)));
        if (((TimerGetRemaining(lv_colonyShipCaptureTimer) <= 0.0) || (UnitGroupCount(lv_capturingPlayerUnits, c_unitCountAlive) <= 0))) {
            break;
        }

        Wait(0.5, c_timeGame);
    }
    if ((UnitGroupCount(lv_capturingPlayerUnits, c_unitCountAlive) <= 0)) {
        gv_bonusStatus[lv_colonyShipIndex] = ge_BonusStatus_Idle;
        libCOUI_gf_ShowHideUnitProgressBar(lv_beacon, false);
        return true;
    }

    gf_StartBonus(lv_colonyShipIndex);
    return true;
}

