//--------------------------------------------------------------------------------------------------
bool gt_StartAI_Func (bool testConds, bool runActions) {
    // Automatic Variable Declarations
    // Actions
    if (!runActions) {
        return true;
    }

    libCOMI_gf_StartCoopAI(gv_pLAYER_03_ENEMY, gv_pLAYER_01_USER);
    libCOMI_gf_SetCoopAIGatherPoint(gv_pLAYER_03_ENEMY, PlayerStartLocation(gv_pLAYER_03_ENEMY));
    libCOMI_gf_StartCoopAI(gv_pLAYER_04_ENEMY, gv_pLAYER_02_USER);
    libCOMI_gf_SetCoopAIGatherPoint(gv_pLAYER_03_ENEMY, PlayerStartLocation(gv_pLAYER_04_ENEMY));
    PlayerSetDifficulty(gv_pLAYER_05_COLONISTS, 4);
    AICampaignStart(gv_pLAYER_05_COLONISTS);
    libNtve_gf_DeclareNextTown(gv_pLAYER_05_COLONISTS, RegionGetCenter(RegionFromId(28)));
    AIToggleBulliesInRegion(gv_pLAYER_05_COLONISTS, RegionFromId(28), true);
    AIAddHealer(gv_pLAYER_05_COLONISTS, "ColonistSCV", "Repair", 0);
    AIAttackWaveSetGatherPoint(gv_pLAYER_05_COLONISTS, PointFromId(749652359));
    AISetDifficulty(gv_pLAYER_05_COLONISTS, c_diffEnableDangerMap, true);
    AISetDifficulty(gv_pLAYER_05_COLONISTS, c_diffWaveAvoidDanger, true);
    gv_aPCAttackValue[1] = 2;
    gv_aPCAttackValue[2] = 3;
    gv_aPCAttackValue[3] = 6;
    gv_aPCAttackValue[4] = 20;
    gv_aPCAttackValue[5] = 18;
    gv_aPCAttackValue[6] = 30;
    TriggerExecute(gt_AttackWaves, true, false);
    TriggerEnable(gt_APCMarineRespawn, true);
    TriggerEnable(gt_APCCleanSCV, true);
    TriggerEnable(gt_AITimer, true);
    return true;
}

