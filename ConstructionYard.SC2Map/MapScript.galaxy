            lv_customvalue = FixedToInt(UnitGetCustomValue(autoCB19184C_var, gv_aPC_PATH_CUSTOM_VALUE));
            if ((lv_customvalue == gv_aPCAttackValue[lp_index]) && (lv_sentattack == false)) {
                gf_APCEscortAttack(lp_index, autoCB19184C_var, lp_resource, lp_tech);
                lv_sentattack = true;
            }

            autoEE4A5CBA_val = lv_customvalue;
            if (autoEE4A5CBA_val == (gv_colonistsRouteCount[lp_index] + 3)) {
                if ((UnitGroupCount(UnitCargoGroup(autoCB19184C_var), c_unitCountAll) == 0)) {
                    Wait(2.0, c_timeGame);
                    libNtve_gf_SendActorMessageToUnit(autoCB19184C_var, "AnimBracketStop Work");
                    UnitSetPropertyFixed(autoCB19184C_var, c_unitPropMovementSpeed, UnitTypeGetProperty(UnitGetType(autoCB19184C_var), c_unitPropMovementSpeed));
                    Wait(2.0, c_timeGame);
                    UnitIssueOrder(autoCB19184C_var, OrderTargetingPoint(AbilityCommand("move", 0), PointFromName(("Colonist Camp " + IntToString(lp_index) + " - Park Here"))), c_orderQueueReplace);
                    UnitIssueOrder(autoCB19184C_var, Order(AbilityCommand("move", 2)), c_orderQueueAddToEnd);
