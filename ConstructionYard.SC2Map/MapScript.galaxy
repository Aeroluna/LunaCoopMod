    libLbty_gf_OrderWorkerstoGatherNearbyResources(RegionPlayableMap(), gv_pLAYER_02_USER);
    Wait(5.0, c_timeAI);
    TriggerQueueEnter();
    TriggerExecute(gt_ObjectiveSixCampsCreate, true, true);
    TriggerExecute(gt_ObjectiveDontDestroyCampsCreate, true, true);
    libCOOC_gf_SetAllSoundChannelVolumesCampaign(libCOOC_ge_VolumeChannelModeCampaign_Speech);
    auto3E807AE9_val = RandomInt(1, 3);
