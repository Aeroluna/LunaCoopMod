// Trigger: APC Marine Respawn
//--------------------------------------------------------------------------------------------------
bool gt_APCMarineRespawn_Func (bool testConds, bool runActions) {
    // Variable Declarations
    int lv_marinecount;

    // Automatic Variable Declarations
    // Variable Initialization
    lv_marinecount = 4;

    // Conditions
    if (testConds) {
        if (!((libCOMI_gf_PlayerInCinematicModeCampaign() == false))) {
            return false;
        }

        if (!((libCOMI_gf_GameIsOver() == false))) {
            return false;
        }
    }

    // Actions
    if (!runActions) {
        return true;
    }

    lv_marinecount = (gv_aPCLaunchCount + 2);
    lv_marinecount = MinI(lv_marinecount, 8);
    if ((UnitGroupCount(UnitGroup("Marine", gv_pLAYER_05_COLONISTS, RegionFromId(28), UnitFilter(0, 0, (1 << c_targetFilterMissile), (1 << (c_targetFilterDead - 32)) | (1 << (c_targetFilterHidden - 32))), 0), c_unitCountAlive) < lv_marinecount)) {
        libNtve_gf_CreateUnitsAtPoint2(1, "Marine", c_unitCreateIgnorePlacement, gv_pLAYER_05_COLONISTS, PointFromId(1583439995));
    }

    if ((UnitGroupCount(UnitGroup("ColonistSCV", gv_pLAYER_05_COLONISTS, RegionFromId(28), UnitFilter(0, 0, (1 << c_targetFilterMissile), (1 << (c_targetFilterDead - 32)) | (1 << (c_targetFilterHidden - 32))), 0), c_unitCountAlive) < 1)) {
        libNtve_gf_CreateUnitsAtPoint2(1, "ColonistSCV", c_unitCreateIgnorePlacement, gv_pLAYER_05_COLONISTS, PointFromId(1583439995));
        lib74A68E34_gf_IssueOrderWithoutScriptControl(UnitLastCreated(), OrderTargetingPoint(AbilityCommand("move", 0), PlayerStartLocation(gv_pLAYER_05_COLONISTS)), c_orderQueueReplace);
    }

    return true;
}

