            else {
                lv_waypoint = PointFromName(("Colonist Camp " + IntToString(lp_index) + " - Waypoint " + IntToString(lv_customvalue)));
                UnitIssueOrder(autoCB19184C_var, OrderTargetingPoint(AbilityCommand("move", 0), lv_waypoint), c_orderQueueReplace);
