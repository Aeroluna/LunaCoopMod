        libCOMI_gf_DisplayCampaignMessage(PlayerGroupSingle(gv_pLAYER_02_USER), libCOMI_ge_CampaignMessageType_MissionFailed, StringExternal("Param/Value/193B0D29"), libCOMI_ge_CampaignMessageFormatNotFormat_FormatMessage);
        lv_l_CameraTarget = PlayerStartLocation(gv_pLAYER_01_USER);
    }
    else {
        libCOMI_gf_DisplayCampaignMessage(PlayerGroupSingle(gv_pLAYER_02_USER), libCOMI_ge_CampaignMessageType_MissionFailed, StringExternal("Param/Value/3FD88F28"), libCOMI_ge_CampaignMessageFormatNotFormat_FormatMessage);
        libCOMI_gf_DisplayCampaignMessage(PlayerGroupSingle(gv_pLAYER_01_USER), libCOMI_ge_CampaignMessageType_MissionFailed, StringExternal("Param/Value/93D8D827"), libCOMI_ge_CampaignMessageFormatNotFormat_FormatMessage);
        lv_l_CameraTarget = PlayerStartLocation(gv_pLAYER_02_USER);
    }
    Wait(2.0, c_timeReal);
    autoFF0D0D2B_g = UnitGroup(null, c_playerAny, RegionEntireMap(), UnitFilter(0, 0, (1 << c_targetFilterMissile), (1 << (c_targetFilterDead - 32)) | (1 << (c_targetFilterHidden - 32))), 0);
    autoFF0D0D2B_u = UnitGroupCount(autoFF0D0D2B_g, c_unitCountAll);
    for (;; autoFF0D0D2B_u -= 1) {
        autoFF0D0D2B_var = UnitGroupUnitFromEnd(autoFF0D0D2B_g, autoFF0D0D2B_u);
