                    if ((UnitIsAlive(autoCB19184C_var) == true)) {
                        AIToggleBulliesInRegion(gv_pLAYER_05_COLONISTS, RegionFromName(("Colonist Camp " + IntToString(lp_index))), true);
                        AIToggleBulliesInRegion(gv_pLAYER_03_ENEMY, RegionFromName(("Colonist Camp " + IntToString(lp_index))), false);
                        AIToggleBulliesInRegion(gv_pLAYER_04_ENEMY, RegionFromName(("Colonist Camp " + IntToString(lp_index))), false);
                        AIToggleBulliesInRegion(gv_pLAYER_03_ENEMY, RegionFromName(("Camp " + IntToString(lp_index) + " Extra Bullies")), false);
                        AIToggleBulliesInRegion(gv_pLAYER_04_ENEMY, RegionFromName(("Camp " + IntToString(lp_index) + " Extra Bullies")), false);
                        AIAttackWaveCancel(lp_escort);
                        AISetGroupScriptControlled(lv_cargo, false);
