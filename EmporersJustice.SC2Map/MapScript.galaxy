//--------------------------------------------------------------------------------------------------
// Trigger: Start Game Q
//--------------------------------------------------------------------------------------------------
bool gt_StartGameQ_Func (bool testConds, bool runActions) {
    // Automatic Variable Declarations
    unitgroup auto52A88B9B_g;
    int auto52A88B9B_u;
    unit auto52A88B9B_var;
    int auto57BD1501_val;

    // Actions
    if (!runActions) {
        return true;
    }

    PortraitCreate(20, 0, c_anchorLeft, 237, 360, "ValerianPortrait", "", "Talk", false, false);
    ConversationDataRegisterPortrait("char_Valerian", PortraitLastCreated());
    UIAlertPoint("Trigger", gv_pLAYER_01_USER, StringToText(""), null, PlayerStartLocation(gv_pLAYER_01_USER));
    UIAlertPoint("Trigger", gv_pLAYER_02_USER, StringToText(""), null, PlayerStartLocation(gv_pLAYER_02_USER));
    libLbty_gf_OrderWorkerstoGatherNearbyResources(RegionPlayableMap(), gv_pLAYER_01_USER);
    libLbty_gf_OrderWorkerstoGatherNearbyResources(RegionPlayableMap(), gv_pLAYER_02_USER);
    auto52A88B9B_g = UnitGroup("SubwayEntranceSW", gv_pLAYER_01_USER, RegionEntireMap(), UnitFilter(0, 0, (1 << c_targetFilterMissile), (1 << (c_targetFilterDead - 32)) | (1 << (c_targetFilterHidden - 32))), 0);
    auto52A88B9B_u = UnitGroupCount(auto52A88B9B_g, c_unitCountAll);
    for (;; auto52A88B9B_u -= 1) {
        auto52A88B9B_var = UnitGroupUnitFromEnd(auto52A88B9B_g, auto52A88B9B_u);
        if (auto52A88B9B_var == null) { break; }
        VisRevealArea(gv_pLAYER_01_USER, RegionCircle(UnitGetPosition(auto52A88B9B_var), 6.0), 0.0, false);
    }
    Wait(5.0, c_timeAI);
    TriggerQueueEnter();
    TriggerExecute(gt_ObjectiveDefeattheDeathFleetCreate, true, true);
    auto57BD1501_val = RandomInt(1, 3);
    if (auto57BD1501_val == 1) {
        libCOMI_gf_SendMissionTransmission("Intro1N08", true, -1);
    }
    else if (auto57BD1501_val == 2) {
        libCOMI_gf_SendMissionTransmission("Intro2N08", true, -1);
    }
    else if (auto57BD1501_val == 3) {
        libCOMI_gf_SendMissionTransmission("Intro3N08", true, -1);
    }
    else {
    }
    Wait(7.0, c_timeAI);
    libCOMI_gf_SendMissionTransmission("ObjectiveFirstPingN08", true, -1);
    SoundPlayForPlayer(SoundLink("PingSound", -1), c_maxPlayers, PlayerGroupAll(), 100.0, 0.0);
    libCOMI_gf_PingMinimapCampaign(PlayerGroupAll(), RegionGetCenter(RegionFromId(3)), 5.0, Color(100.00, 0.00, 0.00));
    libCOMI_gf_PingMinimapCampaign(PlayerGroupAll(), RegionGetCenter(RegionFromId(4)), 5.0, Color(100.00, 0.00, 0.00));
    libCOMI_gf_PingMinimapCampaign(PlayerGroupAll(), RegionGetCenter(RegionFromId(5)), 5.0, Color(100.00, 0.00, 0.00));
    gf_CreateArrowPings(3, 0.0625, 225.0);
    gf_CreateArrowPings(4, 0.0625, 225.0);
    gf_CreateArrowPings(5, 0.0625, 225.0);
    TriggerQueueExit();
    Wait(2.0, c_timeAI);
    TriggerExecute(gt_TipReadyQ, true, false);
    return true;
}

