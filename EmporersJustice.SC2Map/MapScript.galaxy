//--------------------------------------------------------------------------------------------------
// Trigger: Dominion Planetary Dies
//--------------------------------------------------------------------------------------------------
bool gt_DominionPlanetaryDies_Func (bool testConds, bool runActions) {
    // Variable Declarations
    point lv_point;

    // Automatic Variable Declarations
    // Variable Initialization
    lv_point = UnitGetPosition(EventUnit());

    // Conditions
    if (testConds) {
        if (!((UnitGetOwner(EventUnit()) == gv_pLAYER_08_DOMINION))) {
            return false;
        }

        if (!(((UnitGetType(EventUnit()) == "PlanetaryFortress") || (UnitGetType(EventUnit()) == "CommandCenter")))) {
            return false;
        }
    }

    // Actions
    if (!runActions) {
        return true;
    }

    Wait(5.0, c_timeAI);
    libNtve_gf_AICast(UnitGroupClosestToPoint(UnitGroup("SCV", gv_pLAYER_08_DOMINION, RegionEntireMap(), UnitFilter(0, 0, (1 << c_targetFilterMissile), (1 << (c_targetFilterDead - 32)) | (1 << (c_targetFilterHidden - 32))), 0), lv_point), OrderTargetingPoint(AbilityCommand("TerranBuild", 0), lv_point));
    return true;
}

