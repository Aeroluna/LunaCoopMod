    TriggerAddEventUnitConstructProgress(gt_SCVDespawn, null, c_unitProgressStageComplete);
}

//--------------------------------------------------------------------------------------------------
// Trigger: Barracks Construction
//--------------------------------------------------------------------------------------------------
bool gt_BarracksConstruction_Func (bool testConds, bool runActions) {
    // Variable Declarations
    unit lv_barracks;
    region lv_region;

    // Automatic Variable Declarations
    region auto68FDEA7D_val;
    region autoE2F66629_val;

    // Variable Initialization

    // Conditions
    if (testConds) {
        if (!(((UnitGetOwner(EventUnitProgressUnit()) == gv_pLAYER_10_DEFENDERS_LEFT) || (UnitGetOwner(EventUnitProgressUnit()) == gv_pLAYER_11_DEFENDERS_RIGHT)))) {
            return false;
        }

        if (!((UnitGetType(EventUnitProgressUnit()) == "Barracks"))) {
            return false;
        }
    }

    // Actions
    if (!runActions) {
        return true;
    }

    gv_aliveOuterBases += 1;
    lv_barracks = EventUnitProgressUnit();
    if ((libNtve_gf_UnitInRegion(lv_barracks, RegionFromId(1)) == true)) {
        lv_region = RegionFromId(1);
        AIToggleBulliesInRegion(gv_pLAYER_08_DOMINION, RegionFromId(70), true);
    }

    if ((libNtve_gf_UnitInRegion(lv_barracks, RegionFromId(2)) == true)) {
        lv_region = RegionFromId(2);
        AIToggleBulliesInRegion(gv_pLAYER_08_DOMINION, RegionFromId(71), true);
    }

    if ((libNtve_gf_UnitInRegion(lv_barracks, RegionFromId(6)) == true)) {
        lv_region = RegionFromId(6);
        AIToggleBulliesInRegion(gv_pLAYER_08_DOMINION, RegionFromId(76), true);
    }

    if ((libNtve_gf_UnitInRegion(lv_barracks, RegionFromId(7)) == true)) {
        lv_region = RegionFromId(7);
        AIToggleBulliesInRegion(gv_pLAYER_08_DOMINION, RegionFromId(75), true);
    }

    UnitIssueOrder(lv_barracks, Order(AbilityCommand("que5", 0)), c_orderQueueReplace);
    UnitIssueOrder(lv_barracks, OrderTargetingPoint(AbilityCommand("BarracksAddOns", 1), UnitGetPosition(lv_barracks)), c_orderQueueAddToEnd);
    Wait(1.0, c_timeAI);
    AISetUnitScriptControlled(lv_barracks, false);
    if (((lv_region == RegionFromId(1)) || (lv_region == RegionFromId(6)))) {
        Wait(120.0, c_timeAI);
    }
    else {
        Wait(60.0, c_timeAI);
    }
    if ((UnitIsAlive(lv_barracks) == true)) {
        auto68FDEA7D_val = lv_region;
        if (auto68FDEA7D_val == RegionFromId(1)) {
            AIToggleBulliesInRegion(gv_pLAYER_10_DEFENDERS_LEFT, RegionFromId(70), true);
        }
        else if (auto68FDEA7D_val == RegionFromId(2)) {
            AIToggleBulliesInRegion(gv_pLAYER_10_DEFENDERS_LEFT, RegionFromId(71), true);
        }
        else if (auto68FDEA7D_val == RegionFromId(6)) {
            AIToggleBulliesInRegion(gv_pLAYER_11_DEFENDERS_RIGHT, RegionFromId(76), true);
        }
        else if (auto68FDEA7D_val == RegionFromId(7)) {
            AIToggleBulliesInRegion(gv_pLAYER_11_DEFENDERS_RIGHT, RegionFromId(75), true);
        }
        else {
        }
    }

    while (true) {
        Wait(1.0, c_timeAI);
        if ((libCOMI_gf_GameIsOver() == true)) {
            return true;
        }

        if ((UnitIsAlive(lv_barracks) == false)) {
            gv_aliveOuterBases -= 1;
            autoE2F66629_val = lv_region;
            if (autoE2F66629_val == RegionFromId(1)) {
                AIToggleBulliesInRegion(gv_pLAYER_08_DOMINION, RegionFromId(2), false);
                AIToggleBulliesInRegion(gv_pLAYER_10_DEFENDERS_LEFT, RegionFromId(2), false);
                AIToggleBulliesInRegion(gv_pLAYER_03_ENEMY, RegionFromId(1), true);
                AIToggleBulliesInRegion(gv_pLAYER_04_ENEMY, RegionFromId(1), true);
            }
            else if (autoE2F66629_val == RegionFromId(2)) {
                AIToggleBulliesInRegion(gv_pLAYER_08_DOMINION, RegionFromId(2), false);
                AIToggleBulliesInRegion(gv_pLAYER_10_DEFENDERS_LEFT, RegionFromId(2), false);
                AIToggleBulliesInRegion(gv_pLAYER_03_ENEMY, RegionFromId(2), true);
                AIToggleBulliesInRegion(gv_pLAYER_04_ENEMY, RegionFromId(2), true);
            }
            else if (autoE2F66629_val == RegionFromId(6)) {
                AIToggleBulliesInRegion(gv_pLAYER_08_DOMINION, RegionFromId(6), false);
                AIToggleBulliesInRegion(gv_pLAYER_11_DEFENDERS_RIGHT, RegionFromId(6), false);
                AIToggleBulliesInRegion(gv_pLAYER_03_ENEMY, RegionFromId(6), true);
                AIToggleBulliesInRegion(gv_pLAYER_04_ENEMY, RegionFromId(6), true);
            }
            else if (autoE2F66629_val == RegionFromId(7)) {
                AIToggleBulliesInRegion(gv_pLAYER_08_DOMINION, RegionFromId(7), false);
                AIToggleBulliesInRegion(gv_pLAYER_11_DEFENDERS_RIGHT, RegionFromId(7), false);
                AIToggleBulliesInRegion(gv_pLAYER_03_ENEMY, RegionFromId(7), true);
                AIToggleBulliesInRegion(gv_pLAYER_04_ENEMY, RegionFromId(7), true);
            }
            else {
            }
            return true;
        }

    }
    return true;
}

