bool gt_StartAI_Func (bool testConds, bool runActions) {
    // Automatic Variable Declarations
    // Conditions
    if (testConds) {
        if (!((libCOMI_gf_GameIsOver() == false))) {
            return false;
        }
    }

    // Actions
    if (!runActions) {
        return true;
    }

    PlayerSetDifficulty(gv_pLAYER_10_DEFENDERS_LEFT, 4);
    PlayerSetDifficulty(gv_pLAYER_11_DEFENDERS_RIGHT, 4);
    PlayerSetDifficulty(gv_pLAYER_09_DEFENDERS_MID, 4);
    AICampaignStart(gv_pLAYER_10_DEFENDERS_LEFT);
    AICampaignStart(gv_pLAYER_11_DEFENDERS_RIGHT);
    AICampaignStart(gv_pLAYER_09_DEFENDERS_MID);
    PlayerSetDifficulty(gv_pLAYER_08_DOMINION, 4);
    AICampaignStart(gv_pLAYER_08_DOMINION);
    AIReqAddSpecialMaker("Bunker", "SCV", "TerranBuild", 22);
    libCOMI_gf_StartCoopAI(gv_pLAYER_03_ENEMY, gv_pLAYER_01_USER);
    libCOMI_gf_SetCoopAIGatherPoint(gv_pLAYER_03_ENEMY, PlayerStartLocation(gv_pLAYER_03_ENEMY));
    libCOMI_gf_StartCoopAI(gv_pLAYER_04_ENEMY, gv_pLAYER_02_USER);
    libCOMI_gf_SetCoopAIGatherPoint(gv_pLAYER_03_ENEMY, PlayerStartLocation(gv_pLAYER_04_ENEMY));
    gv_waveTarget[gv_pLAYER_03_ENEMY] = PlayerStartLocation(gv_pLAYER_01_USER);
    gv_waveTarget[gv_pLAYER_04_ENEMY] = PlayerStartLocation(gv_pLAYER_02_USER);
    gv_waveTarget[gv_pLAYER_05_ENEMY_AMBIENT] = PlayerStartLocation(gv_pLAYER_01_USER);
    libCOMI_gf_StartCoopMissionMechanicAI(gv_pLAYER_05_ENEMY_AMBIENT, libCOMI_gv_cM_CoopAIPlayer_CommanderShared);
    cai_start("ai14F812AA", gv_pLAYER_05_ENEMY_AMBIENT);
    cai_waves_run(gv_pLAYER_05_ENEMY_AMBIENT, libCOOC_gf_HumanPlayers());
    libCOMI_gf_EnableDisableCoopAIPlayerAttackPings(PlayerGroupSingle(gv_pLAYER_05_ENEMY_AMBIENT), false);
    AIToggleBulliesInRegion(gv_pLAYER_03_ENEMY, RegionFromId(3), false);
    AIToggleBulliesInRegion(gv_pLAYER_04_ENEMY, RegionFromId(3), false);
    AIToggleBulliesInRegion(gv_pLAYER_03_ENEMY, RegionFromId(4), false);
    AIToggleBulliesInRegion(gv_pLAYER_04_ENEMY, RegionFromId(4), false);
    AIToggleBulliesInRegion(gv_pLAYER_03_ENEMY, RegionFromId(5), false);
    AIToggleBulliesInRegion(gv_pLAYER_04_ENEMY, RegionFromId(5), false);
    TriggerExecute(gt_BullyActivationSequence, true, false);
    TimerStart(gv_battlecruiser1Timer, 660.0, false, c_timeAI);
    TimerStart(gv_battlecruiser2Timer, 1080.0, false, c_timeAI);
    TriggerExecute(gt_DefenderSideBasesOnlineQ, true, false);
    TriggerExecute(gt_DefenderBasesMaintainDefenseQ, true, false);
    gv_laneActive[3] = true;
    gv_laneActive[4] = true;
    gv_laneActive[5] = true;
    TriggerExecute(gt_AmbientWavesAICommander, true, false);
    Wait(590.0, c_timeAI);
    gv_laneActive[1] = true;
    gv_laneActive[2] = true;
    gv_laneActive[6] = true;
    gv_laneActive[7] = true;
    return true;
}

