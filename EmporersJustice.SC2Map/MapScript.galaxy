    auto0F5D4521_n = RandomInt(6, 8);
    for (auto0F5D4521_i = 1; auto0F5D4521_i <= auto0F5D4521_n; auto0F5D4521_i += 1) {
        UnitIssueOrder(lv_warpgate, OrderTargetingPoint(AbilityCommand("SuperWarpGateTrain", 7), PointWithOffsetPolar(UnitGetPosition(lv_caster), RandomFixed(4.0, 6.0), libNtve_gf_RandomAngle())), c_orderQueueAddToEnd);
        UnitGroupAdd(gv_bossAdds, UnitLastCreated());
        Wait(0.1, c_timeGame);
    }
    autoC0F72F7C_n = RandomInt(2, 4);
    for (autoC0F72F7C_i = 1; autoC0F72F7C_i <= autoC0F72F7C_n; autoC0F72F7C_i += 1) {
