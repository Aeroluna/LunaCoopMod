//--------------------------------------------------------------------------------------------------
bool gt_DefenderBasesMaintainDefenseQ_Func (bool testConds, bool runActions) {
    // Automatic Variable Declarations
    // Conditions
    if (testConds) {
        if (!((libCOMI_gf_GameIsOver() == false))) {
            return false;
        }
    }

    // Actions
    if (!runActions) {
        return true;
    }

    Wait(350.0, c_timeAI);
    TriggerExecute(gt_BonusEvacuateStart, true, false);
    TriggerQueueEnter();
    if ((libCOMI_gf_GameIsOver() == true)) {
        return true;
    }

    libCOMI_gf_SendMissionTransmission("ObjectiveMaintainingN08", true, -1);
    if ((UnitIsAlive(UnitFromId(2044729735)) == true)) {
        libCOMI_gf_SendMissionTransmission("BonusRevealedN08", true, -1);
        if ((UnitIsAlive(UnitFromId(2044729735)) == true)) {
            libCOMI_gf_PingMinimapCampaign(PlayerGroupAll(), PointFromId(793064925), 5.0, Color(0.00, 100.00, 0.00));
