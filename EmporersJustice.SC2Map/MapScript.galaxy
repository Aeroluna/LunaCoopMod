//--------------------------------------------------------------------------------------------------
bool gt_BossAddSuicideEffect_Func (bool testConds, bool runActions) {
    // Automatic Variable Declarations
    // Actions
    if (!runActions) {
        return true;
    }

    UnitGroupAdd(gv_bossAdds, EventPlayerEffectUsedUnit(c_effectUnitTarget));
    AISetUnitSuicide(EventPlayerEffectUsedUnit(c_effectUnitTarget), true);
    if ((UnitGroupCount(gv_bossAdds, c_unitCountAlive) >= 12)) {
        TechTreeAbilityAllow(gv_pLAYER_05_ENEMY_AMBIENT, AbilityCommand("NovaLeviathanSpawnMutalisk", 0), false);
        TechTreeAbilityAllow(gv_pLAYER_05_ENEMY_AMBIENT, AbilityCommand("NovaLeviathanSpawnBroodLord", 0), false);
    }

    return true;
}

