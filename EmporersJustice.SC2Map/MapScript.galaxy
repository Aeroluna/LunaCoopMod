        libCOMI_gf_DisplayCampaignMessage(PlayerGroupSingle(gv_pLAYER_01_USER), libCOMI_ge_CampaignMessageType_MissionFailed, StringExternal("Param/Value/F539FC16"), libCOMI_ge_CampaignMessageFormatNotFormat_FormatMessage);
        lv_l_CameraTarget = PlayerStartLocation(gv_pLAYER_02_USER);
    }
