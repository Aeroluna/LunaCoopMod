    gt_ScienceFacilityDiesQ = TriggerCreate("gt_ScienceFacilityDiesQ_Func");
    TriggerAddEventUnitDied(gt_ScienceFacilityDiesQ, UnitRefFromUnit(UnitFromId(2044729735)));
}

