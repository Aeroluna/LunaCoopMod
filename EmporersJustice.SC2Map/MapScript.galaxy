    auto19C7210D_g = UnitGroup(null, c_playerAny, RegionEntireMap(), UnitFilter(0, 0, (1 << c_targetFilterMissile), (1 << (c_targetFilterDead - 32)) | (1 << (c_targetFilterHidden - 32))), 0);
    auto19C7210D_u = UnitGroupCount(auto19C7210D_g, c_unitCountAll);
    for (;; auto19C7210D_u -= 1) {
        auto19C7210D_var = UnitGroupUnitFromEnd(auto19C7210D_g, auto19C7210D_u);
        if (auto19C7210D_var == null) { break; }
        UnitIssueOrder(auto19C7210D_var, Order(AbilityCommand("stop", 0)), c_orderQueueReplace);
    }
    libNtve_gf_SetAlliance(gv_pLAYER_01_USER, gv_pLAYER_03_ENEMY, libNtve_ge_AllianceSetting_Ally);
    libNtve_gf_SetAlliance(gv_pLAYER_01_USER, gv_pLAYER_04_ENEMY, libNtve_ge_AllianceSetting_Ally);
    libNtve_gf_SetAlliance(gv_pLAYER_02_USER, gv_pLAYER_03_ENEMY, libNtve_ge_AllianceSetting_Ally);
    libNtve_gf_SetAlliance(gv_pLAYER_02_USER, gv_pLAYER_04_ENEMY, libNtve_ge_AllianceSetting_Ally);
    libNtve_gf_SetAlliance(gv_pLAYER_03_ENEMY, gv_pLAYER_01_USER, libNtve_ge_AllianceSetting_Ally);
    libNtve_gf_SetAlliance(gv_pLAYER_03_ENEMY, gv_pLAYER_02_USER, libNtve_ge_AllianceSetting_Ally);
    libNtve_gf_SetAlliance(gv_pLAYER_04_ENEMY, gv_pLAYER_01_USER, libNtve_ge_AllianceSetting_Ally);
    libNtve_gf_SetAlliance(gv_pLAYER_04_ENEMY, gv_pLAYER_02_USER, libNtve_ge_AllianceSetting_Ally);
    CameraLockInput(gv_pLAYER_01_USER, true);
    CameraLockInput(gv_pLAYER_02_USER, true);
    UnitClearSelection(gv_pLAYER_01_USER);
    UnitClearSelection(gv_pLAYER_02_USER);
    UISetSelectionTypeEnabled(PlayerGroupAll(), c_localSelectionTypeUnknown, false);
    if ((RegionContainsPoint(RegionCircle(lv_l_CameraTarget, 8.0), CameraGetTarget(gv_pLAYER_01_USER)) == false)) {
        CameraApplyInfo(gv_pLAYER_01_USER, CameraInfoDefault(), 2.0, -1, 10.0, false);
        CameraPan(gv_pLAYER_01_USER, lv_l_CameraTarget, 2.0, -1, 10.0, false);
