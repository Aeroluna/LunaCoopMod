//--------------------------------------------------------------------------------------------------
// Trigger: Objective - Science Facility - Update
//--------------------------------------------------------------------------------------------------
bool gt_ObjectiveScienceFacilityUpdate_Func (bool testConds, bool runActions) {
    // Automatic Variable Declarations
    // Actions
    if (!runActions) {
        return true;
    }

    TriggerExecute(gt_ObjectiveScienceFacilityCreate, true, false);
    libCOMI_gf_SetMissionObjectiveProgress("Nova08Bonus01", gv_objectiveScienceFacilityProgress);
    if ((gv_objectiveScienceFacilityProgress >= 3)) {
        TriggerExecute(gt_ObjectiveScienceFacilityComplete, true, false);
    }

    return true;
}

