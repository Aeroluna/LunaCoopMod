    ai14F812AA_wave8_run(p, target, true);
    ai14F812AA_wave9_run(p, target, true);
    ai14F812AA_wave10_run(p, target, true);
    ai14F812AA_wave12_run(p, target, true);

    while (true) {
        ai14F812AA_wave12_run(p, target, true);
    }

    return true;
}

