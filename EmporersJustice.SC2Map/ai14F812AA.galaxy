bool ai14F812AA_waves_runFunc (bool c, bool a) {
    int p = ai14F812AA_waves_runPlayer;
    playergroup target = ai14F812AA_waves_runTarget;

    if (p < 0 || p >= 16) {
        return false;
    }

    ai14F812AA_wave1_run(p, target, true);
    ai14F812AA_wave2_run(p, target, true);
    ai14F812AA_wave3_run(p, target, true);
    ai14F812AA_wave4_run(p, target, true);
    ai14F812AA_wave11_run(p, target, true);
    ai14F812AA_wave5_run(p, target, true);
    ai14F812AA_wave6_run(p, target, true);
