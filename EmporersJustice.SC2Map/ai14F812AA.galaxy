//--------------------------------------------------------------------------------------------------
// Start
//--------------------------------------------------------------------------------------------------
bool ai14F812AA_initialized = false;

//--------------------------------------------------------------------------------------------------
void ai14F812AA_start (int p) {
    int init_i;

    if (p < 0 || p >= 16) {
        return;
    }
    if (!ai14F812AA_initialized) {
        ai14F812AA_wave1_init();
        ai14F812AA_wave2_init();
        ai14F812AA_wave3_init();
        ai14F812AA_wave4_init();
        ai14F812AA_wave11_init();
        ai14F812AA_wave5_init();
        ai14F812AA_wave6_init();
        ai14F812AA_wave7_init();
        ai14F812AA_wave8_init();
        ai14F812AA_wave9_init();
        ai14F812AA_wave10_init();
        ai14F812AA_wave12_init();
        ai14F812AA_waves_init();

        for (init_i = 0; init_i <= 16; init_i += 1) {
            ai14F812AA_defGather[init_i] = PointFromId(0);
        }

        ai14F812AA_initialized = true;
    }

    AICampaignStart(p);
}
