// Trigger: Starting Sequence Q
//--------------------------------------------------------------------------------------------------
bool gt_StartingSequenceQ_Func (bool testConds, bool runActions) {
    // Automatic Variable Declarations
    unitgroup autoB643C5FB_g;
    int autoB643C5FB_u;
    unit autoB643C5FB_var;
    unitgroup auto7E16A6D0_g;
    int auto7E16A6D0_u;
    unit auto7E16A6D0_var;

    // Actions
    if (!runActions) {
        return true;
    }

    TriggerQueueEnter();
    TriggerEnable(gt_ObjectiveSticksnStonesIntialization, true);
    TriggerExecute(gt_ObjectiveRamseyAliveCreate, true, true);
    VisExploreArea(gv_pLAYER_01_USER, RegionFromId(22), true, false);
    VisExploreArea(gv_pLAYER_02_USER, RegionFromId(22), true, false);
    autoB643C5FB_g = UnitGroup("MineralField", c_playerAny, RegionEntireMap(), UnitFilter(0, 0, (1 << c_targetFilterMissile), (1 << (c_targetFilterDead - 32)) | (1 << (c_targetFilterHidden - 32))), 0);
    autoB643C5FB_u = UnitGroupCount(autoB643C5FB_g, c_unitCountAll);
    for (;; autoB643C5FB_u -= 1) {
        autoB643C5FB_var = UnitGroupUnitFromEnd(autoB643C5FB_g, autoB643C5FB_u);
        if (autoB643C5FB_var == null) { break; }
        VisExploreArea(gv_pLAYER_01_USER, RegionCircle(UnitGetPosition(autoB643C5FB_var), 1.0), true, false);
        VisExploreArea(gv_pLAYER_02_USER, RegionCircle(UnitGetPosition(autoB643C5FB_var), 1.0), true, false);
    }
    auto7E16A6D0_g = UnitGroup("SpacePlatformGeyser", c_playerAny, RegionEntireMap(), UnitFilter(0, 0, (1 << c_targetFilterMissile), (1 << (c_targetFilterDead - 32)) | (1 << (c_targetFilterHidden - 32))), 0);
    auto7E16A6D0_u = UnitGroupCount(auto7E16A6D0_g, c_unitCountAll);
    for (;; auto7E16A6D0_u -= 1) {
        auto7E16A6D0_var = UnitGroupUnitFromEnd(auto7E16A6D0_g, auto7E16A6D0_u);
        if (auto7E16A6D0_var == null) { break; }
        VisExploreArea(gv_pLAYER_01_USER, RegionCircle(UnitGetPosition(auto7E16A6D0_var), 1.0), true, false);
        VisExploreArea(gv_pLAYER_02_USER, RegionCircle(UnitGetPosition(auto7E16A6D0_var), 1.0), true, false);
    }
    Wait(2.0, c_timeGame);
    TriggerExecute(gt_IntroVO, true, true);
    libCOMI_gf_CreateObjectivePingAC(libCOMI_ge_ObjectivePingType_Primary, RegionGetCenter(RegionFromId(22)), StringExternal("Param/Value/3562E0D5"));
    Wait(2.5, c_timeGame);
    TriggerExecute(gt_CheckpointsShowresearchfacilities, true, false);
    TriggerQueueExit();
    return true;
}

