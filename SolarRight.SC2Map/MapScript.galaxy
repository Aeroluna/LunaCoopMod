//--------------------------------------------------------------------------------------------------
// Trigger: Objective - Gather Solarite - Update
//--------------------------------------------------------------------------------------------------
bool gt_ObjectiveGatherSolariteUpdate_Func (bool testConds, bool runActions) {
    // Variable Declarations
    int lv_prog;

    // Automatic Variable Declarations
    // Variable Initialization

    // Actions
    if (!runActions) {
        return true;
    }

    TriggerExecute(gt_ObjectiveGatherSolariteCreate, true, false);
    lv_prog = (PlayerGetPropertyInt(gv_pLAYER_01_USER, c_playerPropCustom) + PlayerGetPropertyInt(gv_pLAYER_02_USER, c_playerPropCustom));
    lv_prog = MinI(lv_prog, gv_sOLARITE_GOAL);
    libCOMI_gf_SetMissionObjectiveProgress("SolarGatherGetSolarite", lv_prog);
    return true;
}

