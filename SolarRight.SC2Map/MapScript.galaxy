//--------------------------------------------------------------------------------------------------
// Trigger: Enemy free solarite
//--------------------------------------------------------------------------------------------------
bool gt_Enemyfreesolarite_Func (bool testConds, bool runActions) {
    // Automatic Variable Declarations
    // Actions
    if (!runActions) {
        return true;
    }

    while (true) {
        if ((TriggerIsEnabled(TriggerGetCurrent()) == true) && (libCOMI_gf_GameIsOver() == false)) {
            PlayerModifyPropertyFixed(gv_pLAYER_03_ENEMY, c_playerPropCustom, c_playerPropOperAdd, 3.0);
            Wait(2.0, c_timeAI);
            PlayerModifyPropertyFixed(gv_pLAYER_03_ENEMY, c_playerPropCustom, c_playerPropOperAdd, 2.0);
            Wait(5.0, c_timeAI);
            PlayerModifyPropertyFixed(gv_pLAYER_03_ENEMY, c_playerPropCustom, c_playerPropOperAdd, 1.0);
            Wait(3.0, c_timeAI);
            PlayerModifyPropertyFixed(gv_pLAYER_03_ENEMY, c_playerPropCustom, c_playerPropOperAdd, 2.0);
            Wait(4.0, c_timeAI);
            PlayerModifyPropertyFixed(gv_pLAYER_03_ENEMY, c_playerPropCustom, c_playerPropOperAdd, 1.0);
            Wait(6.0, c_timeAI);
            PlayerModifyPropertyFixed(gv_pLAYER_03_ENEMY, c_playerPropCustom, c_playerPropOperAdd, 2.0);
            Wait(4.0, c_timeAI);
            PlayerModifyPropertyFixed(gv_pLAYER_03_ENEMY, c_playerPropCustom, c_playerPropOperAdd, 1.0);
            Wait(2.0, c_timeAI);
            PlayerModifyPropertyFixed(gv_pLAYER_03_ENEMY, c_playerPropCustom, c_playerPropOperAdd, 3.0);
            Wait(3.0, c_timeAI);
            PlayerModifyPropertyFixed(gv_pLAYER_03_ENEMY, c_playerPropCustom, c_playerPropOperAdd, 1.0);
            Wait(4.0, c_timeAI);
            PlayerModifyPropertyFixed(gv_pLAYER_03_ENEMY, c_playerPropCustom, c_playerPropOperAdd, 1.0);
            Wait(7.0, c_timeAI);
        }
        else {
            break;
        }
    }
    return true;
}

