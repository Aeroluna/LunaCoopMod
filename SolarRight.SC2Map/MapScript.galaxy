//--------------------------------------------------------------------------------------------------
// Trigger: Solarite - Update Objective
//--------------------------------------------------------------------------------------------------
bool gt_SolariteUpdateObjective_Func (bool testConds, bool runActions) {
    // Automatic Variable Declarations
    // Conditions
    if (testConds) {
        if (!((libCOMI_gf_GameIsOver() == false))) {
            return false;
        }

        if (!(((PlayerGetPropertyInt(gv_pLAYER_03_ENEMY, c_playerPropCustom) + PlayerGetPropertyInt(gv_pLAYER_04_ENEMY, c_playerPropCustom)) < gv_tARGET_SOLARITE))) {
            return false;
        }
    }

    // Actions
    if (!runActions) {
        return true;
    }

    if (((PlayerGetPropertyInt(gv_pLAYER_01_USER, c_playerPropCustom) + PlayerGetPropertyInt(gv_pLAYER_02_USER, c_playerPropCustom)) >= gv_objectiveGatherSolariteCurrentTarget)) {
        TriggerExecute(gt_ObjectiveGatherSolariteUpdate, true, true);
        TriggerExecute(gt_ObjectiveGatherSolariteComplete, true, false);
    }
    else {
        if (((PlayerGetPropertyInt(gv_pLAYER_01_USER, c_playerPropCustom) + PlayerGetPropertyInt(gv_pLAYER_02_USER, c_playerPropCustom)) < gv_sOLARITE_GOAL)) {
            TriggerExecute(gt_ObjectiveGatherSolariteUpdate, true, false);
        }

    }
    return true;
}

