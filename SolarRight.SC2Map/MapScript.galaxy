    UnitGroupAddUnitGroup(lv_threatGroup, UnitGroup(null, gv_pLAYER_02_USER, RegionCircle(UnitGetPosition(lp_aiUnit), 15.0), UnitFilter(0, 0, (1 << c_targetFilterMissile), (1 << (c_targetFilterDead - 32)) | (1 << (c_targetFilterHidden - 32))), 0));
    auto42E92871_g = lv_threatGroup;
    auto42E92871_u = UnitGroupCount(auto42E92871_g, c_unitCountAll);
    for (;; auto42E92871_u -= 1) {
