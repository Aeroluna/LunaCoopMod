        if (((PlayerGetPropertyInt(gv_pLAYER_01_USER, c_playerPropCustom) + PlayerGetPropertyInt(gv_pLAYER_02_USER, c_playerPropCustom)) == gv_tARGET_SOLARITE)) {
            TriggerQueueEnter();
            lv_transmissionOn[3] = false;
            libCOOC_gf_SetAllSoundChannelVolumesCampaign(libCOOC_ge_VolumeChannelModeCampaign_Speech);
            libNtve_gf_SendTransmissionSimple(TransmissionSourceFromModel("RamseyPortrait"), libNtve_gf_CinematicPortrait(libNtve_ge_CinematicPortraitPosition_CenterLeft), SoundLink("100Per", -1), 0.0, c_transmissionDurationAdd, true);
            libCOOC_gf_SetAllSoundChannelVolumesCampaign(libCOOC_ge_VolumeChannelModeCampaign_Game);
            TriggerQueueExit();
        }
        else {
            if (((PlayerGetPropertyInt(gv_pLAYER_01_USER, c_playerPropCustom) + PlayerGetPropertyInt(gv_pLAYER_02_USER, c_playerPropCustom)) < gv_tARGET_SOLARITE)) {
                TriggerQueueEnter();
                lv_transmissionOn[3] = false;
                libCOOC_gf_SetAllSoundChannelVolumesCampaign(libCOOC_ge_VolumeChannelModeCampaign_Speech);
                libNtve_gf_SendTransmissionSimple(TransmissionSourceFromModel("RamseyPortrait"), libNtve_gf_CinematicPortrait(libNtve_ge_CinematicPortraitPosition_CenterLeft), SoundLink("ReachTempleBeforeSol", -1), 0.0, c_transmissionDurationAdd, true);
                libCOOC_gf_SetAllSoundChannelVolumesCampaign(libCOOC_ge_VolumeChannelModeCampaign_Game);
                TriggerQueueExit();
            }

        }
    }

    return true;
}

