void gt_SolariteUpdateObjective_Init () {
    gt_SolariteUpdateObjective = TriggerCreate("gt_SolariteUpdateObjective_Func");
    TriggerEnable(gt_SolariteUpdateObjective, false);
    TriggerAddEventPlayerPropChange(gt_SolariteUpdateObjective, 1, c_playerPropCustom);
    TriggerAddEventPlayerPropChange(gt_SolariteUpdateObjective, 2, c_playerPropCustom);
}

