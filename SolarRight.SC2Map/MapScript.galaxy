//--------------------------------------------------------------------------------------------------
// Trigger: Checkpoints - Show research facilities
//--------------------------------------------------------------------------------------------------
bool gt_CheckpointsShowresearchfacilities_Func (bool testConds, bool runActions) {
    // Variable Declarations
    int lv_checkPointIter;
    region lv_checkpoint;
    int lv_activePingsDesired;
    int lv_activePingsTotal;
    int lv_activePingsPrevious;

    // Automatic Variable Declarations
    int auto75A57002_ae;
    const int auto75A57002_ai = 1;

    // Variable Initialization

    // Actions
    if (!runActions) {
        return true;
    }

    auto75A57002_ae = (gv_cONVOY_CHECKPOINTS - 1);
    lv_checkPointIter = 1;
    for ( ; ( (auto75A57002_ai >= 0 && lv_checkPointIter <= auto75A57002_ae) || (auto75A57002_ai < 0 && lv_checkPointIter >= auto75A57002_ae) ) ; lv_checkPointIter += auto75A57002_ai ) {
        lv_checkpoint = RegionFromName(("Checkpoint" + IntToString(lv_checkPointIter)));
        VisExploreArea(gv_pLAYER_01_USER, lv_checkpoint, true, false);
        libCOMI_gf_CreateObjectivePingAC(libCOMI_ge_ObjectivePingType_Primary, RegionGetCenter(lv_checkpoint), StringExternal("Param/Value/C665C304"));
        PingSetScale(PingLastCreated(), 0.5);
        gv_checkpointsObjectivemarkers[lv_checkPointIter] = PingLastCreated();
    }
    Wait(0.7, c_timeGame);
    return true;
}

//--------------------------------------------------------------------------------------------------
void gt_CheckpointsShowresearchfacilities_Init () {
    gt_CheckpointsShowresearchfacilities = TriggerCreate("gt_CheckpointsShowresearchfacilities_Func");
}

//--------------------------------------------------------------------------------------------------
// Trigger: Escort - Roads
//--------------------------------------------------------------------------------------------------
bool gt_EscortRoads_Func (bool testConds, bool runActions) {
    // Variable Declarations
    int lv_road;

    // Automatic Variable Declarations
    const int autoD5D1962D_ae = 4;
    const int autoD5D1962D_ai = 1;

    // Variable Initialization

    // Conditions
    if (testConds) {
        if (!((libCOMI_gf_GameIsOver() == false))) {
            return false;
        }

        if (!((TriggerIsEnabled(TriggerGetCurrent()) == true))) {
            return false;
        }

        if (!((UnitIsAlive(gv_eSCORT_TRUCK) == true))) {
            return false;
        }
    }

    // Actions
    if (!runActions) {
        return true;
    }

    lv_road = 1;
    for ( ; ( (autoD5D1962D_ai >= 0 && lv_road <= autoD5D1962D_ae) || (autoD5D1962D_ai < 0 && lv_road >= autoD5D1962D_ae) ) ; lv_road += autoD5D1962D_ai ) {
        if ((lv_road == (gv_convoyProgress + 1)) && (((PlayerGetPropertyInt(gv_pLAYER_01_USER, c_playerPropCustom) + PlayerGetPropertyInt(gv_pLAYER_02_USER, c_playerPropCustom)) >= gv_checkpointsSolaritelimit[lv_road]) || (TimerGetRemaining(gv_truckExpireTimers[lv_road]) <= 0.0))) {
            if ((TimerGetRemaining(gv_truckExpireTimers[lv_road]) <= 60.0)) {
                TriggerExecute(gt_CheckpointsStartmovingWarningQ, true, false);
            }

            TriggerEnable(TriggerGetCurrent(), false);
            ActorSend(libNtve_gf_MainActorofUnit(gv_eSCORT_TRUCK), "AnimBracketStart Work Stand,Work,Start Stand,Work Stand,Work,End");
            if ((UnitIsAlive(gv_eSCORT_TRUCK) == true)) {
                while (!(((PlayerGetPropertyInt(gv_pLAYER_01_USER, c_playerPropCustom) + PlayerGetPropertyInt(gv_pLAYER_02_USER, c_playerPropCustom)) >= gv_checkpointsSolaritelimit[lv_road]))) {
                    Wait(3.0, c_timeGame);
                }
                gf_Startconvoycountdown(gv_checkpointsWaypointdelay[lv_road], StringExternal("Param/Value/EC286F22"));
                MinimapPing(PlayerGroupAll(), UnitGetPosition(gv_eSCORT_TRUCK), 2.0, libNtve_gf_ConvertPlayerColorToColor(PlayerGetColorIndex(gv_pLAYER_07_ALLY, false)));
                TriggerExecute(gt_CheckpointsStartMovingQ, true, false);
                if ((lv_road == 4)) {
                    TriggerEnable(gt_ObjectiveWaveCycle5, false);
                    TriggerExecute(gt_ObjectiveWaveCycle6, true, false);
                }

                gf_SendEscortTruck(lv_road);
                gv_generatorsActive += 1;
            }

            break;
        }

    }
    return true;
}

//--------------------------------------------------------------------------------------------------
void gt_EscortRoads_Init () {
    gt_EscortRoads = TriggerCreate("gt_EscortRoads_Func");
    TriggerAddEventTimer(gt_EscortRoads, gv_truckExpireTimers[1]);
    TriggerAddEventTimer(gt_EscortRoads, gv_truckExpireTimers[2]);
    TriggerAddEventTimer(gt_EscortRoads, gv_truckExpireTimers[3]);
    TriggerAddEventTimer(gt_EscortRoads, gv_truckExpireTimers[4]);
    TriggerAddEventPlayerPropChange(gt_EscortRoads, 1, c_playerPropCustom);
    TriggerAddEventPlayerPropChange(gt_EscortRoads, 2, c_playerPropCustom);
}

//--------------------------------------------------------------------------------------------------
// Trigger: Escort Progress
//--------------------------------------------------------------------------------------------------
bool gt_EscortProgress_Func (bool testConds, bool runActions) {
    int init_i;

    // Variable Declarations
    bool[5] lv_checkpointOn;

    // Automatic Variable Declarations
    // Variable Initialization
    for (init_i = 0; init_i <= 4; init_i += 1) {
        lv_checkpointOn[init_i] = true;
    }

    // Actions
    if (!runActions) {
        return true;
    }

    while (((gv_path == 1))) {
        if ((gv_path == 1) && (lv_checkpointOn[1] == true) && (gv_convoyProgress == 0)) {
            gv_convoyProgress += 1;
            lv_checkpointOn[1] = false;
            TriggerExecute(gt_CheckpointsTruckArriveQ, true, false);
            return true;
        }

    }
    return true;
}

//--------------------------------------------------------------------------------------------------
void gt_EscortProgress_Init () {
    gt_EscortProgress = TriggerCreate("gt_EscortProgress_Func");
}

