    // Automatic Variable Declarations
    // Actions
    if (!runActions) {
        return true;
    }

    TriggerExecute(gt_ObjectiveSticksnStonesCreate, true, false);
    TextExpressionSetToken("Param/Expression/E86F037D", "TIMER", TextTimeFormat(StringToText("<mintotal/>:<sec2/>"), FixedToInt(TimerGetRemaining(gv_sticksExpireTimer))));
    TextExpressionSetToken("Param/Expression/E86F037D", "COLOR", StringToText("FFFFFF"));
    libCOMI_gf_SetMissionObjectiveCustomText("SolarGatherSticksnStones", TextExpressionAssemble("Param/Expression/E86F037D"));
    return true;
}

