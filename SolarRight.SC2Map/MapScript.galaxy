//--------------------------------------------------------------------------------------------------
bool gt_SolariteTurnobjectiveprogressbaron_Func (bool testConds, bool runActions) {
    // Automatic Variable Declarations
    // Conditions
    if (testConds) {
        if (!((libCOMI_gf_GameIsOver() == false))) {
            return false;
        }

        if (!((TriggerIsEnabled(TriggerGetCurrent()) == true))) {
            return false;
        }
    }

    // Actions
    if (!runActions) {
        return true;
    }

    TriggerEnable(TriggerGetCurrent(), false);
    gf_CreateSolariteProgressBar();
    TriggerExecute(gt_ObjectiveGatherSolariteCreate, true, false);
    TriggerEnable(gt_SolariteUpdateObjective, true);
    return true;
}

