//--------------------------------------------------------------------------------------------------
// Trigger: Gather Solarite - Text Tags
//--------------------------------------------------------------------------------------------------
bool gt_GatherSolariteTextTags_Func (bool testConds, bool runActions) {
    // Automatic Variable Declarations
    // Actions
    if (!runActions) {
        return true;
    }

    TextTagDestroy(libHots_gf_TextTagForUnit(EventUnit(), 1));
    if ((PlayerGroupHasPlayer(libCOOC_gf_CommanderPlayers(), UnitGetOwner(EventUnit())) == true)) {
        if ((UnitBehaviorCount(EventUnit(), "CarrySolarite") == gv_maxSolarite)) {
            TextTagCreate((StringExternal("Param/Value/6569CDE7") + IntToText(UnitBehaviorCount(EventUnit(), "CarrySolarite")) + StringExternal("Param/Value/8CA822A4") + IntToText(gv_maxSolarite) + StringExternal("Param/Value/9CAA0249")), 16, UnitGetPosition(EventUnit()), 1.0, true, false, gv_hUMAN_PLAYERS);
            TextTagFogofWar(TextTagLastCreated(), true);
            TextTagAttachToUnit(TextTagLastCreated(), EventUnit(), 2.0);
            libHots_gf_StoreTextTagForUnit(EventUnit(), 1, TextTagLastCreated());
        }
        else {
            if ((UnitBehaviorCount(EventUnit(), "CarrySolarite") > 0)) {
                TextTagCreate((IntToText(UnitBehaviorCount(EventUnit(), "CarrySolarite")) + StringExternal("Param/Value/B782FB25") + IntToText(gv_maxSolarite) + StringExternal("Param/Value/06FF8EA3")), 16, UnitGetPosition(EventUnit()), 1.0, true, false, gv_hUMAN_PLAYERS);
                TextTagFogofWar(TextTagLastCreated(), true);
                TextTagAttachToUnit(TextTagLastCreated(), EventUnit(), 2.0);
                libHots_gf_StoreTextTagForUnit(EventUnit(), 1, TextTagLastCreated());
            }

        }
    }
    else {
        if ((UnitBehaviorCount(EventUnit(), "CarrySolarite") == 10)) {
            TextTagCreate((StringExternal("Param/Value/99E8B7DB") + IntToText(UnitBehaviorCount(EventUnit(), "CarrySolarite")) + StringExternal("Param/Value/C1216376") + IntToText(10) + StringExternal("Param/Value/BFA6B459")), 16, UnitGetPosition(EventUnit()), 1.0, true, false, gv_hUMAN_PLAYERS);
            TextTagFogofWar(TextTagLastCreated(), true);
            TextTagAttachToUnit(TextTagLastCreated(), EventUnit(), 2.0);
            libHots_gf_StoreTextTagForUnit(EventUnit(), 1, TextTagLastCreated());
        }
        else {
            if ((UnitBehaviorCount(EventUnit(), "CarrySolarite") > 0)) {
                TextTagCreate((IntToText(UnitBehaviorCount(EventUnit(), "CarrySolarite")) + StringExternal("Param/Value/E750F5B8") + IntToText(10) + StringExternal("Param/Value/1AE935EB")), 16, UnitGetPosition(EventUnit()), 1.0, true, false, gv_hUMAN_PLAYERS);
                TextTagFogofWar(TextTagLastCreated(), true);
                TextTagAttachToUnit(TextTagLastCreated(), EventUnit(), 2.0);
                libHots_gf_StoreTextTagForUnit(EventUnit(), 1, TextTagLastCreated());
            }

        }
    }
    return true;
}

