//--------------------------------------------------------------------------------------------------
bool gt_MapProgression_Func (bool testConds, bool runActions) {
    // Automatic Variable Declarations
    // Actions
    if (!runActions) {
        return true;
    }

    gf_AttackWaveatTime((2.5 * 60.0), gt_AttackWave01);
    TimerStart(gv_truckExpireTimers[1], (3.25 * 60.0), false, c_timeGame);
    gf_HarassWaveatTime((3.5 * 60.0), gt_ObjectiveWaveCycle1);
    gf_AttackWaveatTime((5.5 * 60.0), gt_AttackWave02);
    TimerStart(gv_truckExpireTimers[2], (6.4 * 60.0), false, c_timeGame);
    gf_HarassWaveatTime((6.75 * 60.0), gt_ObjectiveWaveCycle2);
    gf_AttackWaveatTime((10.0 * 60.0), gt_AttackWave03ExpoAttack);
    TimerStart(gv_truckExpireTimers[3], (12.0 * 60.0), false, c_timeGame);
    gf_HarassWaveatTime((12.5 * 60.0), gt_ObjectiveWaveCycle3);
    gf_AttackWaveatTime((15.5 * 60.0), gt_AttackWave04OppositeExpoAttack);
    TimerStart(gv_startBonusObjective, (16.1 * 60.0), false, c_timeGame);
    gf_HarassWaveatTime((17.0 * 60.0), gt_ObjectiveWaveCycle4);
    gf_AttackWaveatTime((20.0 * 60.0), gt_AttackWave05);
    TimerStart(gv_truckExpireTimers[4], (21.5 * 60.0), false, c_timeGame);
    gf_HarassWaveatTime((22.0 * 60.0), gt_ObjectiveWaveCycle5);
    gf_AttackWaveatTime((25.0 * 60.0), gt_AttackWave06);
    return true;
}

