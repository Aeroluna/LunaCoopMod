void gt_SolariteReturnPath_Init () {
    gt_SolariteReturnPath = TriggerCreate("gt_SolariteReturnPath_Func");
    TriggerAddEventUnitAbility(gt_SolariteReturnPath, null, AbilityCommand("ReturnSolariteDummy", 0), c_unitAbilStageExecute, false);
}

