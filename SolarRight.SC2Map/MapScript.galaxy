//--------------------------------------------------------------------------------------------------
// Trigger: Solarite Minimap Icon
//--------------------------------------------------------------------------------------------------
bool gt_SolariteMinimapIcon_Func (bool testConds, bool runActions) {
    int init_i;

    // Variable Declarations
    unit lv_carryingUnit;
    int[3] lv_carryingPing;
    string lv_crystalPingModel;
    fixed lv_crystalPingScale;

    // Automatic Variable Declarations
    playergroup auto147B99D8_g;
    int auto147B99D8_var;

    // Variable Initialization
    for (init_i = 0; init_i <= 2; init_i += 1) {
        lv_carryingPing[init_i] = c_invalidPingId;
    }

    // Conditions
    if (testConds) {
        if (!((libCOMI_gf_GameIsOver() == false))) {
            return false;
        }
    }

    // Actions
    if (!runActions) {
        return true;
    }

    lv_carryingUnit = EventUnit();
    if (((UnitHasBehavior2(lv_carryingUnit, "CarrySolarite") == false) || (UnitGroupHasUnit(gv_solariteHolders, lv_carryingUnit) == true))) {
        return true;
    }

    UnitGroupAdd(gv_solariteHolders, lv_carryingUnit);
    auto147B99D8_g = libCOOC_gf_HumanPlayers();
    auto147B99D8_var = -1;
    while (true) {
        auto147B99D8_var = PlayerGroupNextPlayer(auto147B99D8_g, auto147B99D8_var);
        if (auto147B99D8_var < 0) { break; }
        if ((UnitGetOwner(lv_carryingUnit) == auto147B99D8_var)) {
            lv_crystalPingModel = "PingXenonCrystalGreenIcon";
            lv_crystalPingScale = 0.12;
        }
        else {
            lv_crystalPingModel = "PingXenonCrystalOrangeIcon";
            lv_crystalPingScale = 0.1;
        }
        libCOMI_gf_CreatePingFacingAngleCoop(PlayerGroupSingle(auto147B99D8_var), UnitGetPosition(lv_carryingUnit), 270.0, lv_crystalPingModel, ColorWithAlpha(0.00, 0.00, 0.00, 0.00), 0.0);
        PingSetScale(PingLastCreated(), lv_crystalPingScale);
        lv_carryingPing[auto147B99D8_var] = PingLastCreated();
        PingSetUnit(lv_carryingPing[auto147B99D8_var], lv_carryingUnit);
        PingSetTooltip(PingLastCreated(), StringExternal("Param/Value/831255C3"));
    }
    while ((UnitIsAlive(lv_carryingUnit) == true) && (UnitHasBehavior2(lv_carryingUnit, "CarrySolarite") == true)) {
        Wait(0.25, c_timeGame);
    }
    PingDestroy(lv_carryingPing[gv_pLAYER_01_USER]);
    PingDestroy(lv_carryingPing[gv_pLAYER_02_USER]);
    UnitGroupRemove(gv_solariteHolders, lv_carryingUnit);
    return true;
}

//--------------------------------------------------------------------------------------------------
void gt_SolariteMinimapIcon_Init () {
    gt_SolariteMinimapIcon = TriggerCreate("gt_SolariteMinimapIcon_Func");
    TriggerAddEventUnitBehaviorChange(gt_SolariteMinimapIcon, null, "CarrySolarite", c_unitBehaviorChangeCreate);
}

//--------------------------------------------------------------------------------------------------
// Trigger: Solarite Return Path
//--------------------------------------------------------------------------------------------------
bool gt_SolariteReturnPath_Func (bool testConds, bool runActions) {
    // Variable Declarations
    unit lv_carryingUnit;
    int[3] lv_workerPath;
    string lv_stepIconAsModel;
    string lv_stepIconAsImage;

    // Automatic Variable Declarations
    playergroup auto53D0AC7E_g;
    int auto53D0AC7E_var;

    // Variable Initialization

    // Conditions
    if (testConds) {
        if (!((libCOMI_gf_GameIsOver() == false))) {
            return false;
        }
    }

    // Actions
    if (!runActions) {
        return true;
    }

    lv_carryingUnit = EventUnit();
    if (((UnitHasBehavior2(lv_carryingUnit, "CarrySolarite") == false) || (UnitGroupHasUnit(gv_solaritePaths, lv_carryingUnit) == true))) {
        return true;
    }

    UnitGroupAdd(gv_solariteHolders, lv_carryingUnit);
    auto53D0AC7E_g = libCOOC_gf_HumanPlayers();
    auto53D0AC7E_var = -1;
    while (true) {
        auto53D0AC7E_var = PlayerGroupNextPlayer(auto53D0AC7E_g, auto53D0AC7E_var);
        if (auto53D0AC7E_var < 0) { break; }
        PathCreateForUnit(PlayerGroupSingle(auto53D0AC7E_var), lv_carryingUnit);
        lv_workerPath[auto53D0AC7E_var] = PathLastCreated();
        PathSetVisible(lv_workerPath[auto53D0AC7E_var], c_pathLocationAll, true);
        PathSetDestinationPoint(lv_workerPath[auto53D0AC7E_var], OrderGetTargetPosition(EventUnitOrder()));
        if ((UnitGetOwner(lv_carryingUnit) == auto53D0AC7E_var)) {
            PathSetColor(lv_workerPath[auto53D0AC7E_var], c_pathLocationAll, Color(0.00, 100.00, 0.00));
        }
        else {
            PathSetColor(lv_workerPath[auto53D0AC7E_var], c_pathLocationAll, libNtve_gf_ConvertPlayerColorToColor(PlayerGetColorIndex(UnitGetOwner(lv_carryingUnit), false)));
        }
        lv_stepIconAsModel = "Assets\\Units\\Test\\InvisibleUnit\\InvisibleUnit.m3";
        lv_stepIconAsImage = lv_stepIconAsModel;
        PathSetStepModel(lv_workerPath[auto53D0AC7E_var], c_pathLocationWorld, lv_stepIconAsImage);
    }
    while ((UnitIsAlive(lv_carryingUnit) == true) && (UnitHasBehavior2(lv_carryingUnit, "CarrySolarite") == true) && (UnitOrderHasAbil(EventUnit(), "ReturnSolariteDummy") == true)) {
        Wait(0.25, c_timeGame);
    }
    PathDestroy(lv_workerPath[gv_pLAYER_01_USER]);
    PathDestroy(lv_workerPath[gv_pLAYER_02_USER]);
    UnitGroupRemove(gv_solaritePaths, lv_carryingUnit);
    return true;
}

