    int autoA7305CE4_val;
    const int autoCF6278B5_ae = gv_mAX_BUTTONS;
    int autoCF6278B5_var;

    // Variable Initialization

    // Actions
    if (!runActions) {
        return true;
    }

    lv_i = 1;
    for ( ; ( (autoDE83BCE0_ai >= 0 && lv_i <= autoDE83BCE0_ae) || (autoDE83BCE0_ai < 0 && lv_i >= autoDE83BCE0_ae) ) ; lv_i += autoDE83BCE0_ai ) {
        if ((EventDialogControl() == gv_mapButton[lv_i])) {
            autoA7305CE4_val = lv_i;
            if (autoA7305CE4_val == gv_rANDOM_BUTTON_ID) {
                autoCF6278B5_var = gv_mAP_ID_START;
                for ( ; autoCF6278B5_var <= autoCF6278B5_ae; autoCF6278B5_var += 1 ) {
                    if ((libNtve_gf_DialogItemIsChecked(gv_mapCheck[autoCF6278B5_var], EventPlayer()) == true)) {
                        lv_random_ids[lv_random_id_count] = autoCF6278B5_var;
                        lv_random_id_count += 1;
