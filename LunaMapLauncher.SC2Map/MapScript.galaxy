void InitGlobals () {
    int init_i;

    for (init_i = 0; init_i <= gv_mAX_BUTTONS; init_i += 1) {
        gv_mapButton[init_i] = c_invalidDialogControlId;
    }
    for (init_i = 0; init_i <= gv_mAX_BUTTONS; init_i += 1) {
        gv_mapCheck[init_i] = c_invalidDialogControlId;
    }
    gv_offsetY = -400;
    gv_checkDialog = c_invalidDialogId;
    gv_increment = gv_mAP_ID_START;
}

