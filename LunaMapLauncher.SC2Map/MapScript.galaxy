    // Variable Initialization

    // Actions
    if (!runActions) {
        return true;
    }

    lv_i = gv_mAP_ID_START;
    for ( ; ( (auto6A02F16B_ai >= 0 && lv_i <= auto6A02F16B_ae) || (auto6A02F16B_ai < 0 && lv_i >= auto6A02F16B_ae) ) ; lv_i += auto6A02F16B_ai ) {
        if ((EventDialogControl() == gv_mapCheck[lv_i])) {
            if ((libNtve_gf_DialogItemIsChecked(EventDialogControl(), EventPlayer()) == true)) {
