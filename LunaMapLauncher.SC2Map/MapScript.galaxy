//--------------------------------------------------------------------------------------------------
// Global Functions
//--------------------------------------------------------------------------------------------------
void gf_LoadMap (int lp_slot) {
    // Automatic Variable Declarations
    // Implementation
    if ((GameIsOnline() == true)) {
        OnlineMapToMapLoad(lp_slot, GameAttributePlayersForTeam(1), PlayerGroupEmpty());
    }
    else {
        TextExpressionSetToken("Param/Expression/89F652FB", "A", IntToText(lp_slot));
        TriggerDebugOutput(1, TextExpressionAssemble("Param/Expression/89F652FB"), true);
    }
}

void gf_CreateMapButton (text lp_text, bool lp_enabled) {
    // Automatic Variable Declarations
    // Implementation
    TextExpressionSetToken("Param/Expression/E78FBCB6", "A", lp_text);
    libNtve_gf_DisplayScreenButton(gv_increment, TextExpressionAssemble("Param/Expression/E78FBCB6"), gv_bUTTON_WIDTH, gv_bUTTON_HEIGHT, c_anchorCenter, gv_offsetX, gv_offsetY, null);
    libNtve_gf_SetScreenButtonBorderImage(gv_increment, "Assets\\Textures\\ui_generic_button_normalpressed.dds", "Assets\\Textures\\ui_generic_button_normaloverpressedover.dds", c_triggerImageTypeBorder);
    gv_mapButton[gv_increment] = libNtve_gf_ScreenButton(gv_increment);
    if ((lp_enabled == true)) {
        libNtve_gf_CreateDialogItemCheckBox(gv_checkDialog, 50, gv_bUTTON_HEIGHT, c_anchorCenter, 0, gv_offsetY, StringToText(""), true);
    }
    else {
        DialogControlSetEnabled(gv_mapButton[gv_increment], PlayerGroupAll(), false);
        libNtve_gf_CreateDialogItemCheckBox(gv_checkDialog, 50, gv_bUTTON_HEIGHT, c_anchorCenter, 0, gv_offsetY, StringToText(""), false);
    }
    gv_mapCheck[gv_increment] = DialogControlLastCreated();
    gv_offsetY += gv_sPACING_Y;
    gv_increment += 1;
}

//--------------------------------------------------------------------------------------------------
// Trigger: UI Setup
//--------------------------------------------------------------------------------------------------
bool gt_UISetup_Func (bool testConds, bool runActions) {
    // Automatic Variable Declarations
    // Actions
    if (!runActions) {
        return true;
    }

    libNtve_gf_HideGameUI(false, PlayerGroupAll());
    UISetWorldVisible(PlayerGroupAll(), false);
    CameraLockInput(1, true);
    CameraLockInput(2, true);
    PlayerSetRace(1, "Terr");
    PlayerSetRace(2, "Terr");
    libNtve_gf_DisplayScreenImage(1, "Assets\\Textures\\ui_void_loading_epilogue02.dds", c_triggerBlendModeAdd, 2120, 1200, c_anchorCenter, 0, 0);
    libNtve_gf_DisplayScreenLabel(1, StringExternal("Param/Value/03542E23"), "Kicker_Minerals", 700, 200, c_anchorTop, 0, 50);
    gv_offsetX = -300;
    DialogCreate(100, 1000, c_anchorCenter, (gv_offsetX + 220), 0, true);
    DialogSetImageVisible(DialogLastCreated(), false);
    DialogSetVisible(DialogLastCreated(), PlayerGroupAll(), true);
    gv_checkDialog = DialogLastCreated();
    libNtve_gf_DisplayScreenLabel(2, StringExternal("Param/Value/A36E4E2E"), "Kicker_Minerals", gv_bUTTON_WIDTH, gv_bUTTON_HEIGHT, c_anchorCenter, gv_offsetX, gv_offsetY);
    gv_offsetY += gv_sPACING_Y;
    gf_CreateMapButton(StringExternal("Param/Value/555F28C2"), true);
    gf_CreateMapButton(StringExternal("Param/Value/114AC014"), true);
    gf_CreateMapButton(StringExternal("Param/Value/F851ACAB"), true);
    gf_CreateMapButton(StringExternal("Param/Value/B2EC6FED"), true);
    gf_CreateMapButton(StringExternal("Param/Value/5781BB5F"), true);
    gf_CreateMapButton(StringExternal("Param/Value/8D69E053"), true);
    gf_CreateMapButton(StringExternal("Param/Value/DEBD310D"), true);
    gf_CreateMapButton(StringExternal("Param/Value/46006C7A"), true);
    gf_CreateMapButton(StringExternal("Param/Value/B463BDA9"), true);
    gf_CreateMapButton(StringExternal("Param/Value/20A95614"), true);
    gf_CreateMapButton(StringExternal("Param/Value/3393E09C"), true);
    gf_CreateMapButton(StringExternal("Param/Value/E7B9D407"), true);
    gf_CreateMapButton(StringExternal("Param/Value/A4CA97E0"), true);
    gf_CreateMapButton(StringExternal("Param/Value/12E07CE9"), true);
    gf_CreateMapButton(StringExternal("Param/Value/97DF9038"), true);
    gv_offsetX = 0;
    libNtve_gf_DisplayScreenButton(gv_rANDOM_BUTTON_ID, StringExternal("Param/Value/A13B65F0"), gv_bUTTON_WIDTH, gv_bUTTON_HEIGHT, c_anchorCenter, gv_offsetX, gv_offsetY, null);
    libNtve_gf_SetDialogItemTooltip(libNtve_gf_ScreenButton(gv_rANDOM_BUTTON_ID), StringExternal("Param/Value/B9A5F19D"), PlayerGroupAll());
    libNtve_gf_SetScreenButtonBorderImage(gv_rANDOM_BUTTON_ID, "Assets\\Textures\\ui_generic_button_normalpressed.dds", "Assets\\Textures\\ui_generic_button_normaloverpressedover.dds", c_triggerImageTypeBorder);
    gv_mapButton[gv_rANDOM_BUTTON_ID] = libNtve_gf_ScreenButton(gv_rANDOM_BUTTON_ID);
    gv_offsetX = 300;
    gv_offsetY = -400;
    DialogCreate(100, 1000, c_anchorCenter, (gv_offsetX + 220), 0, true);
    DialogSetImageVisible(DialogLastCreated(), false);
    DialogSetVisible(DialogLastCreated(), PlayerGroupAll(), true);
    gv_checkDialog = DialogLastCreated();
    libNtve_gf_DisplayScreenLabel(3, StringExternal("Param/Value/A9F63507"), "Kicker_Minerals", gv_bUTTON_WIDTH, gv_bUTTON_HEIGHT, c_anchorCenter, gv_offsetX, gv_offsetY);
    gv_offsetY += gv_sPACING_Y;
    gf_CreateMapButton(StringExternal("Param/Value/C55AAA07"), false);
    gf_CreateMapButton(StringExternal("Param/Value/931657B5"), false);
    return true;
}

