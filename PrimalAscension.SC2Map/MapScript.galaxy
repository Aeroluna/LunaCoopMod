//--------------------------------------------------------------------------------------------------
bool gt_AIGiveResources_Func (bool testConds, bool runActions) {
    // Automatic Variable Declarations
    playergroup auto9F66BE42_g;
    int auto9F66BE42_var;

    // Conditions
    if (testConds) {
        if (!((TriggerIsEnabled(TriggerGetCurrent()) == true))) {
            return false;
        }

        if (!((libCOMI_gf_GameIsOver() == false))) {
            return false;
        }

        if (!((libCOMI_gf_PlayerInCinematicModeCampaign() == false))) {
            return false;
        }
    }

    // Actions
    if (!runActions) {
        return true;
    }

    auto9F66BE42_g = gv_eNEMY_GROUP;
    auto9F66BE42_var = -1;
    while (true) {
        auto9F66BE42_var = PlayerGroupNextPlayer(auto9F66BE42_g, auto9F66BE42_var);
        if (auto9F66BE42_var < 0) { break; }
        if ((auto9F66BE42_var == gv_pLAYER_05_PRIMALZERG)) {
            continue;
        }

        PlayerModifyPropertyInt(auto9F66BE42_var, c_playerPropMinerals, c_playerPropOperSetTo, 10000);
        PlayerModifyPropertyInt(auto9F66BE42_var, c_playerPropVespene, c_playerPropOperSetTo, 10000);
    }
    return true;
}

