//--------------------------------------------------------------------------------------------------
// Trigger: Sleep Inactive Units
//--------------------------------------------------------------------------------------------------
bool gt_SleepInactiveUnits_Func (bool testConds, bool runActions) {
    // Variable Declarations
    unitgroup lv_placedUnits;
    unit lv_sleepyUnit;
    playergroup lv_sleepyOwners;
    int lv_sleepyPlayer;

    // Automatic Variable Declarations
    playergroup auto82907206_g;
    playergroup auto999E5D62_g;
    unitgroup autoA4BE5D4A_g;
    int autoA4BE5D4A_u;

    // Variable Initialization
    lv_placedUnits = UnitGroupEmpty();
    lv_sleepyOwners = PlayerGroupEmpty();

    // Actions
    if (!runActions) {
        return true;
    }

    PlayerGroupAdd(lv_sleepyOwners, gv_pLAYER_03_ENEMY);
    PlayerGroupAdd(lv_sleepyOwners, gv_pLAYER_04_ENEMY);
    auto82907206_g = lv_sleepyOwners;
    lv_sleepyPlayer = -1;
    while (true) {
        lv_sleepyPlayer = PlayerGroupNextPlayer(auto82907206_g, lv_sleepyPlayer);
        if (lv_sleepyPlayer < 0) { break; }
        UnitGroupAddUnitGroup(lv_placedUnits, UnitGroup(null, lv_sleepyPlayer, RegionFromId(7), UnitFilter(0, 0, (1 << c_targetFilterMissile), (1 << (c_targetFilterDead - 32)) | (1 << (c_targetFilterHidden - 32))), 0));
    }
    while (!((gv_gameHasBegun == true))) {
        Wait(1.0, c_timeGame);
    }
    auto999E5D62_g = lv_sleepyOwners;
    lv_sleepyPlayer = -1;
    while (true) {
        lv_sleepyPlayer = PlayerGroupNextPlayer(auto999E5D62_g, lv_sleepyPlayer);
        if (lv_sleepyPlayer < 0) { break; }
        if ((PlayerRace(lv_sleepyPlayer) == "Terr")) {
            Wait(30.0, c_timeAI);
            break;
        }

    }
    autoA4BE5D4A_g = lv_placedUnits;
    autoA4BE5D4A_u = UnitGroupCount(autoA4BE5D4A_g, c_unitCountAll);
    for (;; autoA4BE5D4A_u -= 1) {
        lv_sleepyUnit = UnitGroupUnitFromEnd(autoA4BE5D4A_g, autoA4BE5D4A_u);
        if (lv_sleepyUnit == null) { break; }
        libCOMI_gf_SleepWakeUpUnitCoop(lv_sleepyUnit, true, libCOMI_ge_SleepWakeUpExcludeOption_RespectExclusions);
    }
    return true;
}

